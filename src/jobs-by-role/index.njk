---
layout: layouts/base.njk
title: "Tech Jobs by Role with Visa Sponsorship | Find Your Perfect Position"
description: "Browse visa-sponsored tech jobs by role. Find software engineering, data science, DevOps, and other tech positions with relocation support across Europe."
permalink: /jobs-by-role/
---

{% block structuredData %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "CollectionPage",
  "name": "Tech Jobs by Role with Visa Sponsorship",
  "description": "Browse visa-sponsored tech jobs organized by role across Europe and worldwide.",
  "url": "{{ site.url }}/jobs-by-role/",
  "publisher": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "BreadcrumbList",
  "itemListElement": [
    { "@type": "ListItem", "position": 1, "name": "Home", "item": "{{ site.url }}/" },
    { "@type": "ListItem", "position": 2, "name": "Jobs by Role", "item": "{{ site.url }}/jobs-by-role/" }
  ]
}
</script>
{% endblock %}

{# Hero #}
<section class="bg-gradient-to-b from-brand-50 to-white dark:from-gray-900 dark:to-gray-950 py-12 md:py-16">
  <div class="max-w-6xl mx-auto px-4">
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Home</a>
      <i data-lucide="chevron-right" class="w-3.5 h-3.5"></i>
      <span class="text-gray-900 dark:text-white font-medium">Jobs by Role</span>
    </nav>
    <h1 class="text-3xl md:text-5xl font-extrabold text-gray-900 dark:text-white mb-4 tracking-tight">
      Tech Jobs by Role
    </h1>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl">
      Browse {{ jobs | length }}+ visa-sponsored tech positions organized by role. Find the perfect match for your skills and experience.
    </p>
  </div>
</section>

{# Role Navigation #}
<section class="sticky top-16 z-40 bg-white/80 dark:bg-gray-950/80 backdrop-blur-lg border-b border-gray-200 dark:border-gray-800">
  <div class="max-w-6xl mx-auto px-4">
    <div class="flex overflow-x-auto gap-1 py-3 scrollbar-hide">
      <a href="#software-engineer" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Software Engineer</a>
      <a href="#backend" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Backend</a>
      <a href="#frontend" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Frontend</a>
      <a href="#fullstack" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Full-Stack</a>
      <a href="#data" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Data</a>
      <a href="#devops" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">DevOps / SRE</a>
      <a href="#mobile" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Mobile</a>
      <a href="#ml" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">ML / AI</a>
      <a href="#security" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Security</a>
      <a href="#manager" class="whitespace-nowrap px-3 py-1.5 text-sm rounded-lg hover:bg-brand-50 dark:hover:bg-brand-900/30 text-gray-600 dark:text-gray-400 hover:text-brand-600 dark:hover:text-brand-400 transition-colors">Engineering Manager</a>
    </div>
  </div>
</section>

{# ---- Software Engineer ---- #}
<section id="software-engineer" class="py-12 scroll-mt-32">
  <div class="max-w-3xl mx-auto px-4">
    <div class="flex items-center gap-3 mb-6">
      <div class="w-10 h-10 bg-brand-100 dark:bg-brand-900/30 rounded-xl flex items-center justify-center">
        <i data-lucide="code-2" class="w-5 h-5 text-brand-600 dark:text-brand-400"></i>
      </div>
      <h2 class="section-heading">Software Engineer</h2>
    </div>
    <div class="space-y-4">
      {% set count = { val: 0 } %}
      {% for job in jobs %}
      {% if "Software Engineer" in job.position and "Backend" not in job.position and "Frontend" not in job.position and "Full" not in job.position and "Data" not in job.position and "Machine Learning" not in job.position and "Security" not in job.position and "Mobile" not in job.position %}
      {% if count.val < 10 %}
      <div class="job-card">
        <div class="flex flex-col sm:flex-row sm:items-start gap-4">
          <img src="{{ job.logo }}" alt="{{ job.company }}" class="w-12 h-12 rounded-lg object-cover shrink-0" loading="lazy" onerror="this.src='/favicon/android-chrome-192x192.png'">
          <div class="flex-1 min-w-0">
            <h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-1">{{ job.position }}</h3>
            <p class="text-gray-600 dark:text-gray-400 mb-2">{{ job.company }}</p>
            <div class="flex flex-wrap items-center gap-x-4 gap-y-1 text-sm text-gray-500 dark:text-gray-400 mb-3">
              <span class="flex items-center gap-1">
                <i data-lucide="map-pin" class="w-3.5 h-3.5"></i>
                {{ job.location }}
              </span>
              <span class="flex items-center gap-1">
                <i data-lucide="clock" class="w-3.5 h-3.5"></i>
                {{ job.post_date | timeAgo }}
              </span>
            </div>
            <div class="flex flex-wrap gap-2">
              {% if job.visa %}<span class="badge badge-visa">{{ job.visa }}</span>{% endif %}
              <span class="badge badge-contract">{{ job.contract }}</span>
            </div>
          </div>
          <a href="{{ job.description }}" target="_blank" rel="noopener" class="job-card-apply">
            Apply <i data-lucide="external-link" class="w-3.5 h-3.5 ml-1.5"></i>
          </a>
        </div>
      </div>
      {% endif %}
      {% set count = { val: count.val + 1 } %}
      {% endif %}
      {% endfor %}
    </div>
    {% if count.val > 10 %}
    <div class="mt-4 text-center">
      <a href="/visa-sponsored-jobs/?q=software+engineer" class="btn-secondary text-sm">
        View all {{ count.val }} Software Engineer jobs <i data-lucide="arrow-right" class="w-4 h-4 ml-1"></i>
      </a>
    </div>
    {% endif %}
  </div>
</section>

<hr class="border-gray-200 dark:border-gray-800 max-w-3xl mx-auto">

