<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">

  {# Dark mode - prevent flash #}
  <script>
    (function(){
      const t = localStorage.getItem('theme');
      if (t === 'dark' || (!t && window.matchMedia('(prefers-color-scheme: dark)').matches)) {
        document.documentElement.classList.add('dark');
      }
    })();
  </script>

  {# Primary Meta Tags #}
  <title>{% if title %}{{ title }}{% if site.name not in title %} | {{ site.name }}{% endif %}{% else %}{{ site.name }}{% endif %}</title>
  <meta name="title" content="{{ title or site.name }}">
  <meta name="description" content="{{ description or site.description }}">

  {# Open Graph #}
  <meta property="og:type" content="{{ ogType or 'website' }}">
  <meta property="og:url" content="{{ site.url }}{{ page.url }}">
  <meta property="og:title" content="{{ title or site.name }}">
  <meta property="og:description" content="{{ description or site.description }}">
  <meta property="og:image" content="{{ ogImage or (site.url + '/media/og-image.png') }}">

  {# Twitter #}
  <meta property="twitter:card" content="summary_large_image">
  <meta property="twitter:url" content="{{ site.url }}{{ page.url }}">
  <meta property="twitter:title" content="{{ title or site.name }}">
  <meta property="twitter:description" content="{{ description or site.description }}">
  <meta property="twitter:image" content="{{ ogImage or (site.url + '/media/og-image.png') }}">

  <link rel="canonical" href="{{ site.url }}{{ page.url }}">

  {# Favicon #}
  <link rel="icon" type="image/png" sizes="16x16" href="/favicon/favicon-16x16.png">
  <link rel="icon" type="image/png" sizes="32x32" href="/favicon/favicon-32x32.png">
  <link rel="icon" href="/favicon.ico">
  <link rel="icon" type="image/png" sizes="192x192" href="/favicon/android-chrome-192x192.png">
  <link rel="apple-touch-icon" href="/favicon/apple-touch-icon.png">
  <link rel="manifest" href="/favicon/site.webmanifest">

  {# Fonts #}
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700;800&display=swap" rel="stylesheet">

  {# Styles #}
  <link rel="stylesheet" href="/assets/css/styles.css">

  {# Lucide Icons #}
  <script defer src="https://cdn.jsdelivr.net/npm/lucide@0.460.0/dist/umd/lucide.min.js"></script>

  {# Core JS utilities (debounce, timeAgo) — must load before page scripts #}
  <script src="/assets/js/main.js"></script>

  {# Pagefind #}
  <link rel="stylesheet" href="/pagefind/pagefind-ui.css">

  <meta name="robots" content="{{ 'noindex, nofollow' if noindex else 'index, follow' }}">
  <meta name="language" content="English">
  <meta name="google-adsense-account" content="{{ site.analytics.adsense }}">

  {# Structured Data #}
  {% block structuredData %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "{{ site.name }}",
    "url": "{{ site.url }}",
    "description": "{{ site.description }}",
    "potentialAction": {
      "@type": "SearchAction",
      "target": "{{ site.url }}/visa-sponsored-jobs/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  }
  </script>
  {% endblock %}

  {# Article schema for blog posts #}
  {% if date and readTime %}
  <script type="application/ld+json">
  {
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": "{{ title }}",
    "description": "{{ description }}",
    "datePublished": "{{ date | isoDate }}",
    "dateModified": "{{ date | isoDate }}",
    "author": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" },
    "publisher": {
      "@type": "Organization",
      "name": "{{ site.name }}",
      "url": "{{ site.url }}",
      "logo": { "@type": "ImageObject", "url": "{{ site.url }}/favicon/android-chrome-512x512.png" }
    },
    "mainEntityOfPage": "{{ site.url }}{{ page.url }}",
    "url": "{{ site.url }}{{ page.url }}"
  }
  </script>
  {% endif %}

  {# Google Privacy & Messaging / GDPR Consent CMP #}
  <script async src="https://fundingchoicesmessages.google.com/i/{{ site.analytics.adsense | replace('ca-', '') }}?ers=1"></script>
  <script>
    (function() {
      function signalGooglefcPresent() {
        if (!window.frames['googlefcPresent']) {
          if (document.body) {
            var iframe = document.createElement('iframe');
            iframe.style = 'width: 0; height: 0; border: none; z-index: -1000; left: -1000px; top: -1000px;';
            iframe.style.display = 'none';
            iframe.name = 'googlefcPresent';
            document.body.appendChild(iframe);
          } else {
            setTimeout(signalGooglefcPresent, 0);
          }
        }
      }
      signalGooglefcPresent();
    })();
  </script>

  {# APITiny #}
  <script src="https://cdn.apitiny.net/scripts/v2.0/main.js" data-site-id="6a59e0f456c42782b82b22d9" data-test-mode="false" async></script>

  {% block head %}{% endblock %}
</head>

<body class="min-h-screen flex flex-col font-sans">
  {% include "partials/header.njk" %}
  {% include "partials/social-sidebar.njk" %}

  <main class="flex-1">
    {{ content | safe }}
  </main>

  {# Sticky Sidebar Ad — visible on wide screens in the right gutter #}
  {% if not hideSidebarAd %}
  <div class="hidden 2xl:block fixed right-6 top-1/2 -translate-y-1/2 w-72 z-40" id="sidebar-ad-wrapper">
    {% include "partials/sidebar-ad.njk" %}
  </div>
  {% endif %}

  {% include "partials/footer.njk" %}

  {% block scripts %}{% endblock %}

  {# Analytics - GA4 + AdSense #}
  <script async src="https://www.googletagmanager.com/gtag/js?id={{ site.analytics.ga }}"></script>
  <script>
    window.dataLayer = window.dataLayer || [];
    function gtag(){dataLayer.push(arguments);}
    gtag('js', new Date());
    gtag('config', '{{ site.analytics.ga }}');
  </script>
  <script async src="https://pagead2.googlesyndication.com/pagead/js/adsbygoogle.js?client={{ site.analytics.adsense }}" crossorigin="anonymous"></script>
  {% include "partials/telegram-popup.njk" %}
</body>
</html>

