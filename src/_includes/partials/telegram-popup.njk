{# Telegram alert popup — centered modal, appears after 3s (inspired by jaabz.com) #}
<style>
  #tg-popup-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  #tg-popup-backdrop.backdrop-visible {
    opacity: 1;
    pointer-events: all;
  }
  #tg-popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -40%) scale(0.95);
    width: 420px;
    max-width: calc(100vw - 32px);
    z-index: 9999;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
    opacity: 0;
    pointer-events: none;
  }
  #tg-popup.popup-visible {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    pointer-events: all;
  }
  #tg-popup.popup-hidden {
    transform: translate(-50%, -40%) scale(0.95);
    opacity: 0;
    pointer-events: none;
  }
  .tg-popup-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.06);
  }
  .dark .tg-popup-card {
    background: #1a1f2e;
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
  .tg-popup-body {
    padding: 28px 28px 24px;
    text-align: center;
  }
  .tg-popup-close {
    position: absolute;
    top: 14px;
    right: 14px;
    background: none;
    border: none;
    cursor: pointer;
    color: #9ca3af;
    padding: 4px;
    border-radius: 8px;
    line-height: 1;
    transition: color 0.2s, background 0.2s;
    z-index: 1;
  }
  .tg-popup-close:hover {
    color: #374151;
    background: #f3f4f6;
  }
  .dark .tg-popup-close:hover {
    color: #e5e7eb;
    background: rgba(255,255,255,0.1);
  }
  .tg-popup-icon {
    width: 56px;
    height: 56px;
    background: linear-gradient(135deg, #0088cc 0%, #229ED9 100%);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 16px;
  }
  .tg-popup-title {
    font-size: 20px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 6px;
    line-height: 1.3;
  }
  .dark .tg-popup-title {
    color: #f9fafb;
  }
  .tg-popup-desc {
    font-size: 14px;
    color: #4b5563;
    margin: 0 0 4px;
    line-height: 1.5;
  }
  .dark .tg-popup-desc {
    color: #9ca3af;
  }
  .tg-popup-free {
    display: inline-block;
    background: #d1fae5;
    color: #065f46;
    font-size: 11px;
    font-weight: 700;
    padding: 2px 8px;
    border-radius: 4px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    margin-left: 4px;
    vertical-align: middle;
  }
  .dark .tg-popup-free {
    background: rgba(16, 185, 129, 0.2);
    color: #6ee7b7;
  }
  .tg-popup-btn {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    width: 100%;
    padding: 14px 20px;
    background: linear-gradient(135deg, #0088cc 0%, #229ED9 100%);
    color: #fff;
    border: none;
    border-radius: 12px;
    font-size: 15px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: inherit;
    text-decoration: none;
    margin-top: 20px;
  }
  .tg-popup-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }
  .tg-popup-dismiss {
    display: block;
    background: none;
    border: none;
    cursor: pointer;
    color: #9ca3af;
    font-size: 13px;
    margin: 12px auto 0;
    padding: 4px 8px;
    transition: color 0.2s;
    font-family: inherit;
  }
  .tg-popup-dismiss:hover {
    color: #6b7280;
  }
  .dark .tg-popup-dismiss:hover {
    color: #d1d5db;
  }
</style>

<div id="tg-popup-backdrop"></div>

<div id="tg-popup" role="dialog" aria-label="Get job alerts on Telegram">
  <div class="tg-popup-card" style="position:relative;">
    <button id="tg-popup-close" class="tg-popup-close" aria-label="Close">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
    </button>
    <div class="tg-popup-body">
      <div class="tg-popup-icon">
        <svg width="28" height="28" viewBox="0 0 24 24" fill="#ffffff"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
      </div>
      <h3 class="tg-popup-title">Job alerts on Telegram</h3>
      <p class="tg-popup-desc">Get matching job alerts on Telegram <span class="tg-popup-free">FREE</span></p>

      <a href="{{ site.social.telegram }}" target="_blank" rel="noopener" class="tg-popup-btn" id="tg-popup-open-btn">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
        Open Telegram Channel
      </a>

      <button id="tg-popup-dismiss" class="tg-popup-dismiss">Not now</button>
    </div>
  </div>
</div>

<script>
(function() {
  var DISMISS_KEY = "tg_popup_dismissed_v1";
  var popup = document.getElementById("tg-popup");
  var backdrop = document.getElementById("tg-popup-backdrop");
  var closeBtn = document.getElementById("tg-popup-close");
  var dismissBtn = document.getElementById("tg-popup-dismiss");
  var openBtn = document.getElementById("tg-popup-open-btn");

  if (!popup || localStorage.getItem(DISMISS_KEY) === "1") return;

  function show() {
    popup.classList.add("popup-visible");
    popup.classList.remove("popup-hidden");
    if (backdrop) backdrop.classList.add("backdrop-visible");
  }

  function hide() {
    popup.classList.remove("popup-visible");
    popup.classList.add("popup-hidden");
    if (backdrop) backdrop.classList.remove("backdrop-visible");
    localStorage.setItem(DISMISS_KEY, "1");
  }

  // Show after 4 seconds
  setTimeout(show, 4000);

  closeBtn && closeBtn.addEventListener("click", hide);
  dismissBtn && dismissBtn.addEventListener("click", hide);
  backdrop && backdrop.addEventListener("click", hide);

  openBtn && openBtn.addEventListener("click", function() {
    setTimeout(hide, 500);
  });

  // Escape key dismiss
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && popup.classList.contains("popup-visible")) hide();
  });
})();
</script>
