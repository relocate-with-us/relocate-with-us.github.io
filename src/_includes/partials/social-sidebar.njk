{# Sticky Social Sidebar — left side, visible on desktop (like jaabz.com) #}
<style>
  #social-sidebar {
    position: fixed;
    left: 0;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0;
    background: #ffffff;
    border-radius: 0 12px 12px 0;
    box-shadow: 2px 4px 16px rgba(0,0,0,0.08);
    padding: 14px 8px;
    border: 1px solid rgba(0,0,0,0.06);
    border-left: none;
  }
  .dark #social-sidebar {
    background: #1a1f2e;
    border-color: rgba(255,255,255,0.08);
    box-shadow: 2px 4px 16px rgba(0,0,0,0.3);
  }

  #social-sidebar .sidebar-label {
    writing-mode: vertical-lr;
    text-orientation: mixed;
    transform: rotate(180deg);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: #6b7280;
    margin-bottom: 10px;
    padding-bottom: 10px;
    border-bottom: 1px solid #e5e7eb;
  }
  .dark #social-sidebar .sidebar-label {
    color: #9ca3af;
    border-color: rgba(255,255,255,0.1);
  }

  #social-sidebar .sidebar-icon {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 34px;
    height: 34px;
    border-radius: 8px;
    transition: background 0.2s, transform 0.15s;
    color: #6b7280;
  }
  .dark #social-sidebar .sidebar-icon {
    color: #9ca3af;
  }
  #social-sidebar .sidebar-icon:hover {
    transform: scale(1.12);
  }
  #social-sidebar .sidebar-icon.telegram-icon {
    color: #0088cc;
  }
  #social-sidebar .sidebar-icon.telegram-icon:hover {
    background: rgba(0,136,204,0.1);
  }
  #social-sidebar .sidebar-icon.linkedin-icon {
    color: #0a66c2;
  }
  #social-sidebar .sidebar-icon.linkedin-icon:hover {
    background: rgba(10,102,194,0.1);
  }

  /* Hide on smaller screens */
  @media (max-width: 1023px) {
    #social-sidebar {
      display: none;
    }
  }
</style>

<div id="social-sidebar">
  <span class="sidebar-label">FOLLOW</span>

  <a href="{{ site.social.telegram }}" target="_blank" rel="noopener" class="sidebar-icon telegram-icon" aria-label="Telegram" title="Follow on Telegram">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M11.944 0A12 12 0 0 0 0 12a12 12 0 0 0 12 12 12 12 0 0 0 12-12A12 12 0 0 0 12 0a12 12 0 0 0-.056 0zm4.962 7.224c.1-.002.321.023.465.14a.506.506 0 0 1 .171.325c.016.093.036.306.02.472-.18 1.898-.962 6.502-1.36 8.627-.168.9-.499 1.201-.82 1.23-.696.065-1.225-.46-1.9-.902-1.056-.693-1.653-1.124-2.678-1.8-1.185-.78-.417-1.21.258-1.91.177-.184 3.247-2.977 3.307-3.23.007-.032.014-.15-.056-.212s-.174-.041-.249-.024c-.106.024-1.793 1.14-5.061 3.345-.479.33-.913.49-1.302.48-.428-.008-1.252-.241-1.865-.44-.752-.245-1.349-.374-1.297-.789.027-.216.325-.437.893-.663 3.498-1.524 5.83-2.529 6.998-3.014 3.332-1.386 4.025-1.627 4.476-1.635z"/></svg>
  </a>

  <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener" class="sidebar-icon linkedin-icon" aria-label="LinkedIn" title="Follow on LinkedIn">
    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
  </a>
</div>
