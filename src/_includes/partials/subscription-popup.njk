{# Premium, Non-Intrusive Subscription Popup #}
<div id="subscription-popup" class="fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/60 backdrop-blur-sm opacity-0 pointer-events-none transition-opacity duration-300">
  <div class="relative w-full max-w-lg bg-white dark:bg-gray-900 rounded-3xl shadow-2xl overflow-hidden transform scale-95 transition-transform duration-300 border border-gray-100 dark:border-gray-800">
    
    {# Close Button #}
    <button id="close-popup-btn" class="absolute top-4 right-4 text-gray-400 hover:text-gray-600 dark:hover:text-gray-200 transition-colors p-2 rounded-full hover:bg-gray-100 dark:hover:bg-gray-800" aria-label="Close popup">
      <i data-lucide="x" class="w-5 h-5"></i>
    </button>

    {# Top Accents / Gradient Banner #}
    <div class="h-3 bg-gradient-to-r from-brand-500 via-indigo-500 to-purple-600"></div>

    <div class="p-8 sm:p-10">
      {# Logo Icon #}
      <div class="w-16 h-16 bg-brand-50 dark:bg-brand-950/50 rounded-2xl flex items-center justify-center mb-6 border border-brand-100/50 dark:border-brand-900/30">
        <i data-lucide="mail-open" class="w-8 h-8 text-brand-600 dark:text-brand-400"></i>
      </div>

      {# Text Content #}
      <h3 class="text-2xl sm:text-3xl font-extrabold text-gray-900 dark:text-white mb-2 tracking-tight">
        Join 30,000+ Job Seekers
      </h3>
      <p class="text-gray-600 dark:text-gray-400 mb-6 text-sm sm:text-base leading-relaxed">
        Get weekly curated visa-sponsored jobs, relocation tips, and immigration guides delivered directly to your inbox.
      </p>

      {# Mailchimp Subscription Form #}
      <form action="{{ site.mailchimp.action }}" method="post" target="_blank" novalidate id="popup-subscribe-form" class="mb-6">
        <div class="flex flex-col sm:flex-row gap-3">
          <input type="email" name="EMAIL" placeholder="Enter your email address..." required
            class="input-field flex-1 text-sm py-3 px-4">
          <button type="submit" class="btn-primary whitespace-nowrap px-6 py-3 text-sm font-semibold shadow-lg shadow-brand-500/20">
            Subscribe Free
          </button>
        </div>
        <div style="position:absolute;left:-5000px" aria-hidden="true">
          <input type="text" name="{{ site.mailchimp.honeypot }}" tabindex="-1" value="">
        </div>
      </form>

      {# Divider #}
      <div class="relative flex py-2 items-center mb-6">
        <div class="flex-grow border-t border-gray-200 dark:border-gray-800"></div>
        <span class="flex-shrink mx-4 text-gray-400 dark:text-gray-500 text-xs font-semibold uppercase tracking-wider">Or Join Our Communities</span>
        <div class="flex-grow border-t border-gray-200 dark:border-gray-800"></div>
      </div>

      {# Social Buttons #}
      <div class="grid grid-cols-2 gap-4">
        <a href="{{ site.social.linkedin }}" target="_blank" rel="noopener" class="flex items-center justify-center gap-2.5 px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-blue-400 dark:hover:border-blue-600 hover:bg-blue-50/30 dark:hover:bg-blue-900/10 text-gray-700 dark:text-gray-300 transition-all font-medium text-sm">
          <svg class="w-5 h-5 text-[#0A66C2]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433c-1.144 0-2.063-.926-2.063-2.065 0-1.138.92-2.063 2.063-2.063 1.14 0 2.064.925 2.064 2.063 0 1.139-.925 2.065-2.064 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
          </svg>
          LinkedIn
        </a>
        <a href="{{ site.social.telegram }}" target="_blank" rel="noopener" class="flex items-center justify-center gap-2.5 px-4 py-3 rounded-2xl border border-gray-200 dark:border-gray-800 hover:border-sky-400 dark:hover:border-sky-600 hover:bg-sky-50/30 dark:hover:bg-sky-900/10 text-gray-700 dark:text-gray-300 transition-all font-medium text-sm">
          <svg class="w-5 h-5 text-[#24A1DE]" fill="currentColor" viewBox="0 0 24 24">
            <path d="M11.944 0C5.344 0 0 5.344 0 12c0 6.656 5.344 12 11.944 12 6.656 0 12-5.344 12-12 0-6.656-5.344-12-12-12zm5.728 8.16l-1.92 9.056c-.144.64-.528.8-.1.688l-2.928-2.16-1.412 1.36c-.16.16-.288.288-.6.288l.208-2.96 5.392-4.88c.24-.208-.048-.32-.368-.112L9.208 13.2l-2.88-.9c-.624-.208-.64-.624.128-.928l11.232-4.336c.528-.208.976.112.784.928z"/>
          </svg>
          Telegram
        </a>
      </div>
    </div>
  </div>
</div>

<script>
document.addEventListener("DOMContentLoaded", function() {
  var popup = document.getElementById("subscription-popup");
  var closeBtn = document.getElementById("close-popup-btn");
  var form = document.getElementById("popup-subscribe-form");

  if (!popup || !closeBtn) return;

  // Check if already dismissed
  if (localStorage.getItem("popup_dismissed") === "true") return;

  function showPopup() {
    popup.classList.remove("opacity-0", "pointer-events-none");
    popup.querySelector(".relative").classList.remove("scale-95");
    popup.querySelector(".relative").classList.add("scale-100");
  }

  function dismissPopup() {
    popup.classList.add("opacity-0", "pointer-events-none");
    popup.querySelector(".relative").classList.remove("scale-100");
    popup.querySelector(".relative").classList.add("scale-95");
    localStorage.setItem("popup_dismissed", "true");
  }

  // Show popup after 5 seconds delay
  setTimeout(showPopup, 5000);

  // Close triggers
  closeBtn.addEventListener("click", dismissPopup);
  popup.addEventListener("click", function(e) {
    if (e.target === popup) dismissPopup();
  });
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape") dismissPopup();
  });
  if (form) {
    form.addEventListener("submit", function() {
      // Dismiss popup when user submits
      setTimeout(dismissPopup, 1000);
    });
  }
});
</script>
