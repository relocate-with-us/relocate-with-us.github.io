{# Centered subscription popup modal — slides and scales up after 3s #}
<style>
  #sub-popup-backdrop {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(0, 0, 0, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 9998;
    opacity: 0;
    transition: opacity 0.4s ease;
    pointer-events: none;
  }
  #sub-popup-backdrop.backdrop-visible {
    opacity: 1;
    pointer-events: all;
  }
  #sub-popup {
    position: fixed;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -40%) scale(0.95);
    width: 420px;
    max-width: calc(100vw - 32px);
    z-index: 9999;
    transition: transform 0.4s cubic-bezier(0.34, 1.56, 0.64, 1), opacity 0.4s ease;
    opacity: 0;
    pointer-events: none;
  }
  #sub-popup.popup-visible {
    transform: translate(-50%, -50%) scale(1);
    opacity: 1;
    pointer-events: all;
  }
  #sub-popup.popup-hidden {
    transform: translate(-50%, -40%) scale(0.95);
    opacity: 0;
    pointer-events: none;
  }
  .sub-popup-card {
    background: #ffffff;
    border-radius: 20px;
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.25);
    overflow: hidden;
    border: 1px solid rgba(0,0,0,0.06);
  }
  .dark .sub-popup-card {
    background: #1a1f2e;
    border-color: rgba(255,255,255,0.08);
    box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.5);
  }
  .sub-popup-top {
    height: 4px;
    background: linear-gradient(90deg, #6366f1, #8b5cf6, #a855f7);
  }
  .sub-popup-body {
    padding: 24px 28px 24px;
  }
  .sub-popup-header {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    gap: 12px;
    margin-bottom: 12px;
  }
  .sub-popup-icon-wrap {
    width: 44px;
    height: 44px;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    font-size: 22px;
  }
  .sub-popup-close {
    background: none;
    border: none;
    cursor: pointer;
    color: #9ca3af;
    padding: 4px;
    border-radius: 8px;
    line-height: 1;
    transition: color 0.2s, background 0.2s;
    flex-shrink: 0;
    margin-top: -4px;
  }
  .sub-popup-close:hover {
    color: #374151;
    background: #f3f4f6;
  }
  .dark .sub-popup-close:hover {
    color: #e5e7eb;
    background: rgba(255,255,255,0.1);
  }
  .sub-popup-title {
    font-size: 18px;
    font-weight: 800;
    color: #111827;
    margin: 0 0 4px;
    line-height: 1.3;
  }
  .dark .sub-popup-title {
    color: #f9fafb;
  }
  .sub-popup-desc {
    font-size: 14px;
    color: #4b5563;
    margin: 0 0 16px;
    line-height: 1.5;
  }
  .dark .sub-popup-desc {
    color: #9ca3af;
  }
  .sub-popup-input {
    width: 100%;
    padding: 12px 16px;
    border: 1.5px solid #e5e7eb;
    border-radius: 10px;
    font-size: 14px;
    color: #111827;
    background: #f9fafb;
    outline: none;
    box-sizing: border-box;
    transition: border-color 0.2s, box-shadow 0.2s;
    margin-bottom: 10px;
    font-family: inherit;
  }
  .dark .sub-popup-input {
    background: rgba(255,255,255,0.06);
    border-color: rgba(255,255,255,0.12);
    color: #f9fafb;
  }
  .sub-popup-input:focus {
    border-color: #6366f1;
    box-shadow: 0 0 0 3px rgba(99,102,241,0.12);
    background: #fff;
  }
  .dark .sub-popup-input:focus {
    background: rgba(255,255,255,0.08);
  }
  .sub-popup-input::placeholder {
    color: #9ca3af;
  }
  .sub-popup-btn {
    width: 100%;
    padding: 12px 18px;
    background: linear-gradient(135deg, #6366f1 0%, #8b5cf6 100%);
    color: #fff;
    border: none;
    border-radius: 10px;
    font-size: 14.5px;
    font-weight: 700;
    cursor: pointer;
    transition: opacity 0.2s, transform 0.15s;
    font-family: inherit;
    letter-spacing: 0.01em;
  }
  .sub-popup-btn:hover {
    opacity: 0.92;
    transform: translateY(-1px);
  }
  .sub-popup-proof {
    font-size: 12px;
    color: #9ca3af;
    text-align: center;
    margin-top: 12px;
  }
  .dark .sub-popup-proof {
    color: #6b7280;
  }
</style>

<div id="sub-popup-backdrop"></div>

<div id="sub-popup" role="dialog" aria-label="Subscribe to weekly visa jobs">
  <div class="sub-popup-card">
    <div class="sub-popup-top"></div>
    <div class="sub-popup-body">

      <div class="sub-popup-header">
        <div style="display:flex;align-items:center;gap:12px;flex:1;">
          <div class="sub-popup-icon-wrap">✈️</div>
          <div style="flex:1;">
            <p class="sub-popup-title">Get Visa Jobs in Your Inbox</p>
          </div>
        </div>
        <button id="sub-popup-close" class="sub-popup-close" aria-label="Close">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/></svg>
        </button>
      </div>

      <p class="sub-popup-desc">Weekly curated jobs with visa sponsorship &amp; relocation — straight to your inbox. Zero spam.</p>

      <form action="{{ site.mailchimp.action }}" method="post" target="_blank" novalidate id="sub-popup-form">
        <input type="email" name="EMAIL" class="sub-popup-input" placeholder="enter your email..." required autocomplete="email">
        <div style="position:absolute;left:-5000px" aria-hidden="true">
          <input type="text" name="{{ site.mailchimp.honeypot }}" tabindex="-1" value="">
        </div>
        <button type="submit" class="sub-popup-btn">
          Get Weekly Jobs &nbsp;→
        </button>
      </form>

      <p class="sub-popup-proof">🎯 8,000+ job seekers already subscribed. Just saying.</p>
    </div>
  </div>
</div>

<script>
(function() {
  var DISMISS_KEY = "sub_popup_dismissed_v2";
  var popup = document.getElementById("sub-popup");
  var backdrop = document.getElementById("sub-popup-backdrop");
  var closeBtn = document.getElementById("sub-popup-close");
  var form = document.getElementById("sub-popup-form");

  if (!popup || localStorage.getItem(DISMISS_KEY) === "1") return;

  function show() {
    popup.classList.add("popup-visible");
    popup.classList.remove("popup-hidden");
    if (backdrop) backdrop.classList.add("backdrop-visible");
  }

  function hide() {
    popup.classList.remove("popup-visible");
    popup.classList.add("popup-hidden");
    if (backdrop) backdrop.classList.remove("backdrop-visible");
    localStorage.setItem(DISMISS_KEY, "1");
  }

  // Slide up and scale from center after 3 seconds
  setTimeout(show, 3000);

  closeBtn && closeBtn.addEventListener("click", hide);
  backdrop && backdrop.addEventListener("click", hide);

  form && form.addEventListener("submit", function() {
    setTimeout(hide, 800);
  });

  // Escape key dismiss
  document.addEventListener("keydown", function(e) {
    if (e.key === "Escape" && popup.classList.contains("popup-visible")) hide();
  });
})();
</script>
