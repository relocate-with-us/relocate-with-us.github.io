{# Sidebar Ad — The Global Move by RelocateMe #}
{# Compact card version for the sidebar on content pages #}
<aside id="sidebar-ad-globalmove">
  <a href="https://relocateme.substack.com/" target="_blank" rel="noopener sponsored"
     class="block card border-2 border-yellow-300 dark:border-yellow-500/40 p-4 group hover:-translate-y-0.5 transition-all duration-300">

    <span class="inline-flex items-center gap-1 px-2 py-0.5 rounded-full text-[10px] font-bold bg-yellow-400 text-yellow-900 mb-3">
      ⭐ Featured
    </span>

    <div class="flex items-center gap-3 mb-3">
      <img src="/media/globalmove_logo.jpeg" alt="The Global Move" class="w-10 h-10 rounded-lg object-cover shrink-0" loading="lazy">
      <div>
        <p class="text-sm font-semibold text-gray-900 dark:text-white group-hover:text-brand-600 dark:group-hover:text-brand-400 transition-colors leading-tight">The Global Move</p>
        <p class="text-xs text-gray-500 dark:text-gray-400">Newsletter · weekly</p>
      </div>
    </div>

    <p class="text-xs text-gray-600 dark:text-gray-400 mb-3 leading-relaxed">
      Curated job board + newsletter for international tech careers.
    </p>

    <div class="flex flex-wrap gap-1.5 mb-3">
      <span class="badge badge-reloc text-[10px] px-2 py-0.5">Relocation</span>
      <span class="badge badge-visa text-[10px] px-2 py-0.5">Visa</span>
      <span class="badge badge-contract text-[10px] px-2 py-0.5">Remote</span>
    </div>

    <span class="btn-primary w-full text-xs py-2">
      Subscribe Free
      <i data-lucide="external-link" class="w-3 h-3 ml-1"></i>
    </span>
  </a>
</aside>
