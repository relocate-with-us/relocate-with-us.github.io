                  <td>CHF 100–150</td>
                  <td>CHF 80–130</td>
                </tr>
                <tr>
                  <td>Health Insurance (Mandatory)</td>
                  <td>CHF 350–550/mo</td>
                  <td>CHF 400–600/mo</td>
                  <td>CHF 300–480/mo</td>
