            <table>
              <thead>
                <tr>
                  <th>Role</th>
                  <th>Junior</th>
                  <th>Mid-Level</th>
                  <th>Senior</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Software Engineer</td>
                  <td>85,000–110,000</td>
                  <td>110,000–140,000</td>
                  <td>140,000–200,000+</td>
                </tr>
                <tr>
                  <td>Data Scientist</td>
                  <td>90,000–115,000</td>
                  <td>115,000–145,000</td>
                  <td>145,000–195,000+</td>
                </tr>
                <tr>
                  <td>Product Manager</td>
                  <td>95,000–120,000</td>
                  <td>120,000–155,000</td>
                  <td>155,000–210,000+</td>
                </tr>
                <tr>
                  <td>Finance / Banking</td>
                  <td>90,000–120,000</td>
                  <td>120,000–180,000</td>
                  <td>180,000–350,000+</td>
