                  <th>Mid-Level</th>
                  <th>Senior</th>
                </tr>
              </thead>
              <tbody>
                <tr>
                  <td>Software Engineer</td>
                  <td>$65,000–$85,000</td>
                  <td>$85,000–$120,000</td>
                  <td>$120,000–$180,000+</td>
                </tr>
                <tr>
