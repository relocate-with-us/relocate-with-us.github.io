---
layout: layouts/base.njk
title: "Pro Access — Visa Sponsor Database & Application Toolkit"
description: "30+ verified visa-sponsoring companies with recruiter contacts, salary data, and PostHog-style application tips. Plus LaTeX resume template and AI prompts."
noindex: true
permalink: /pro/
---

{% block scripts %}
<script src="/assets/js/paywall.js" defer></script>
{% endblock %}

{# ─── PAYWALL GATE ─────────────────────────────────────────────────────────── #}
<div id="paywall-gate" class="fixed inset-0 z-50 flex items-center justify-center bg-gray-950/95 backdrop-blur-sm">
  <div class="w-full max-w-md mx-4 bg-white dark:bg-gray-900 rounded-2xl shadow-2xl p-8 text-center">
    <div class="w-16 h-16 bg-brand-100 dark:bg-brand-900 rounded-2xl flex items-center justify-center mx-auto mb-5">
      <svg class="w-8 h-8 text-brand-600 dark:text-brand-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
      </svg>
    </div>
    <h1 class="text-2xl font-bold text-gray-900 dark:text-white mb-2">Pro Access Required</h1>
    <p class="text-gray-500 dark:text-gray-400 mb-6 text-sm leading-relaxed">
      Enter the password you received after purchase to access the Visa Sponsor Database.
    </p>
    <div class="space-y-3">
      <input
        id="paywall-input"
        type="password"
        placeholder="Enter your access password"
        class="w-full px-4 py-3 rounded-xl border border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800 text-gray-900 dark:text-white placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-brand-500 focus:border-transparent text-center text-lg tracking-widest"
        autocomplete="off"
        spellcheck="false"
      />
      <p id="paywall-error" class="text-red-500 text-sm hidden">Incorrect password. Check your purchase confirmation email.</p>
      <button
        id="paywall-submit"
        class="w-full py-3 bg-brand-600 hover:bg-brand-700 text-white font-semibold rounded-xl transition-colors"
      >
        Unlock Access
      </button>
    </div>
    <p class="text-xs text-gray-400 dark:text-gray-600 mt-5">
      Don't have access yet? <a href="https://visajobs.xyz" class="text-brand-500 hover:underline">Go to visajobs.xyz</a>
    </p>
  </div>
</div>

{# ─── PRO CONTENT (hidden until unlocked) ─────────────────────────────────── #}
<div id="pro-content" class="hidden">

  {# Hero #}
  <section class="bg-gradient-to-b from-brand-50 to-white dark:from-gray-900 dark:to-gray-950 py-12 border-b border-gray-100 dark:border-gray-800">
    <div class="max-w-5xl mx-auto px-4">
      <div class="flex items-center gap-2 mb-4">
        <span class="inline-flex items-center gap-1.5 px-3 py-1 rounded-full bg-brand-100 dark:bg-brand-900 text-brand-700 dark:text-brand-300 text-xs font-semibold uppercase tracking-wide">
          <svg class="w-3.5 h-3.5" fill="currentColor" viewBox="0 0 20 20"><path d="M9.049 2.927c.3-.921 1.603-.921 1.902 0l1.07 3.292a1 1 0 00.95.69h3.462c.969 0 1.371 1.24.588 1.81l-2.8 2.034a1 1 0 00-.364 1.118l1.07 3.292c.3.921-.755 1.688-1.54 1.118l-2.8-2.034a1 1 0 00-1.175 0l-2.8 2.034c-.784.57-1.838-.197-1.539-1.118l1.07-3.292a1 1 0 00-.364-1.118L2.98 8.72c-.783-.57-.38-1.81.588-1.81h3.461a1 1 0 00.951-.69l1.07-3.292z"/></svg>
          Pro Access
        </span>
        <span class="text-xs text-gray-500 dark:text-gray-400">Updated May 2026</span>
      </div>
      <h1 class="text-3xl md:text-4xl font-bold text-gray-900 dark:text-white mb-3">
        Visa Sponsor Database <span class="text-brand-600">+ Application Toolkit</span>
      </h1>
      <p class="text-gray-600 dark:text-gray-400 text-lg max-w-2xl">
        {{ premiumSponsors | length }} verified companies that sponsor visas — with salary ranges, insider application tips, and the specific person to contact at each company.
      </p>
      <div class="flex flex-wrap gap-4 mt-6">
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">{{ premiumSponsors | length }}</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Companies</div>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">8</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Countries</div>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">3</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Bonus downloads</div>
        </div>
        <div class="bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded-xl px-4 py-3">
          <div class="text-2xl font-bold text-gray-900 dark:text-white">Updated</div>
          <div class="text-xs text-gray-500 dark:text-gray-400">Monthly</div>
        </div>
      </div>
    </div>
  </section>

  {# Country tabs + company cards #}
  <section class="max-w-5xl mx-auto px-4 py-10">

    {# Tab bar #}
    {% set countries = premiumSponsors | uniqueField("country") %}
    <div class="flex flex-wrap gap-2 mb-8" id="country-tabs">
      <button data-country="all" class="country-tab active px-4 py-2 rounded-xl text-sm font-medium bg-brand-600 text-white" onclick="filterCountry('all')">
        All ({{ premiumSponsors | length }})
      </button>
      {% for country in countries %}
      {% set count = premiumSponsors | countByField("country", country) %}
      <button data-country="{{ country }}" class="country-tab px-4 py-2 rounded-xl text-sm font-medium bg-gray-100 dark:bg-gray-800 text-gray-700 dark:text-gray-300 hover:bg-brand-50 dark:hover:bg-brand-900 transition-colors" onclick="filterCountry('{{ country }}')">
        {{ country }} ({{ count }})
      </button>
      {% endfor %}
    </div>

    {# Company grid #}
    <div id="company-grid" class="space-y-4">
      {% for co in premiumSponsors %}
      <div class="company-card bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-800 rounded-2xl overflow-hidden" data-country="{{ co.country }}">
        <div class="p-5">
          <div class="flex items-start gap-4">
            {# Logo or initials #}
            <div class="flex-shrink-0 w-12 h-12 rounded-xl bg-gray-100 dark:bg-gray-800 flex items-center justify-center overflow-hidden">
              {% if co.logo %}
              <img src="{{ co.logo }}" alt="{{ co.name }}" class="w-10 h-10 object-contain" onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"/>
              <span style="display:none" class="w-full h-full items-center justify-center text-lg font-bold text-brand-600">{{ co.name[0] }}</span>
              {% else %}
              <span class="text-lg font-bold text-brand-600">{{ co.name[0] }}</span>
              {% endif %}
            </div>

            {# Company info #}
            <div class="flex-1 min-w-0">
              <div class="flex flex-wrap items-center gap-2 mb-1">
                <h3 class="text-base font-bold text-gray-900 dark:text-white">{{ co.name }}</h3>
                <span class="px-2 py-0.5 text-xs rounded-full bg-blue-50 dark:bg-blue-900/30 text-blue-700 dark:text-blue-300 font-medium border border-blue-100 dark:border-blue-800">{{ co.visa }}</span>
                <span class="px-2 py-0.5 text-xs rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">{{ co.industry }}</span>
              </div>
              <div class="text-sm text-gray-500 dark:text-gray-400 flex flex-wrap gap-3">
                <span>📍 {{ co.city }}</span>
                <span>👥 {{ co.size }}</span>
                {% if co.salaryRange %}
                <span>💰 Senior: <strong class="text-gray-700 dark:text-gray-300">{{ co.salaryRange.senior }}</strong></span>
                {% endif %}
              </div>
            </div>

            {# Careers link #}
            <a href="{{ co.careers }}" target="_blank" rel="noopener" class="flex-shrink-0 px-4 py-2 text-sm font-semibold text-brand-600 dark:text-brand-400 border border-brand-200 dark:border-brand-800 rounded-xl hover:bg-brand-50 dark:hover:bg-brand-900 transition-colors">
              Open Roles ↗
            </a>
          </div>

          {# Application Tip — the PostHog-style section #}
          <div class="mt-4">
            <button class="tip-toggle flex items-center gap-2 text-sm font-semibold text-amber-700 dark:text-amber-400 hover:text-amber-800 dark:hover:text-amber-300 transition-colors" data-slug="{{ co.slug }}">
              <svg class="w-4 h-4 flex-shrink-0" fill="currentColor" viewBox="0 0 20 20"><path d="M11 3a1 1 0 10-2 0v1a1 1 0 102 0V3zM15.657 5.757a1 1 0 00-1.414-1.414l-.707.707a1 1 0 001.414 1.414l.707-.707zM18 10a1 1 0 01-1 1h-1a1 1 0 110-2h1a1 1 0 011 1zM5.05 6.464A1 1 0 106.464 5.05l-.707-.707a1 1 0 00-1.414 1.414l.707.707zM5 10a1 1 0 01-1 1H3a1 1 0 110-2h1a1 1 0 011 1zM8 16v-1h4v1a2 2 0 11-4 0zM12 14c.015-.976.284-2.03.784-3H7.216c.5.97.769 2.024.784 3h4z"/></svg>
              How to actually get hired here
              <svg class="tip-chevron w-4 h-4 transition-transform" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7"/></svg>
            </button>
            <div class="tip-content hidden mt-3 p-4 bg-amber-50 dark:bg-amber-900/20 border border-amber-200 dark:border-amber-800/50 rounded-xl text-sm text-gray-700 dark:text-gray-300 leading-relaxed">
              {{ co.applicationTip }}
              {% if co.interviewProcess %}
              <div class="mt-3 pt-3 border-t border-amber-200 dark:border-amber-800/50">
                <span class="font-semibold text-gray-900 dark:text-white">Interview process:</span> {{ co.interviewProcess }}
              </div>
              {% endif %}
              {% if co.techStack %}
              <div class="mt-2 flex flex-wrap gap-1">
                {% for tech in co.techStack %}
                <span class="px-2 py-0.5 bg-white dark:bg-gray-800 border border-gray-200 dark:border-gray-700 rounded text-xs text-gray-600 dark:text-gray-400">{{ tech }}</span>
                {% endfor %}
              </div>
              {% endif %}
            </div>
          </div>

          {# Recruiter contacts #}
          <div class="mt-4 pt-4 border-t border-gray-100 dark:border-gray-800">
            <p class="text-xs font-semibold text-gray-500 dark:text-gray-500 uppercase tracking-wide mb-2">Recruiter Contacts</p>
            <div class="space-y-2">
              {% for rec in co.recruiters %}
              <div class="flex items-center gap-3">
                <div class="w-7 h-7 rounded-full bg-gradient-to-br from-brand-400 to-brand-600 flex items-center justify-center flex-shrink-0">
                  <span class="text-xs font-bold text-white">{{ rec.name[0] if rec.name != "Add from LinkedIn search" else "?" }}</span>
                </div>
                <div class="flex-1 min-w-0">
                  {% if rec.name != "Add from LinkedIn search" %}
                  <span class="text-sm font-medium text-gray-900 dark:text-white">{{ rec.name }}</span>
                  <span class="text-xs text-gray-500 dark:text-gray-400 ml-2">{{ rec.title }}</span>
                  {% else %}
                  <span class="text-sm text-gray-500 dark:text-gray-400 italic">Recruiter contact to be added</span>
                  {% endif %}
                  {% if rec.note %}
                  <p class="text-xs text-gray-400 dark:text-gray-600 mt-0.5">💡 {{ rec.note }}</p>
                  {% endif %}
                </div>
                {% if rec.linkedin %}
                <a href="{{ rec.linkedin }}" target="_blank" rel="noopener" class="flex-shrink-0 px-3 py-1 text-xs font-medium bg-blue-600 hover:bg-blue-700 text-white rounded-lg transition-colors">
                  LinkedIn
                </a>
                {% endif %}
              </div>
              {% endfor %}
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>
  </section>

  {# ─── BONUS SECTION ──────────────────────────────────────────────────────── #}
