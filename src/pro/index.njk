</div>{# end #pro-content #}

<script>
function filterCountry(country) {
  document.querySelectorAll('.country-tab').forEach(btn => {
    if (btn.dataset.country === country) {
      btn.classList.add('bg-brand-600', 'text-white');
      btn.classList.remove('bg-gray-100', 'dark:bg-gray-800', 'text-gray-700', 'dark:text-gray-300');
    } else {
      btn.classList.remove('bg-brand-600', 'text-white');
      btn.classList.add('bg-gray-100', 'text-gray-700');
    }
  });
  document.querySelectorAll('.company-card').forEach(card => {
    if (country === 'all' || card.dataset.country === country) {
      card.style.display = '';
    } else {
      card.style.display = 'none';
    }
  });
}

document.querySelectorAll('.tip-toggle').forEach(btn => {
  btn.addEventListener('click', () => {
    const content = btn.nextElementSibling;
    const chevron = btn.querySelector('.tip-chevron');
    content.classList.toggle('hidden');
    chevron.classList.toggle('rotate-180');
  });
});
</script>
