<script>
(function() {
  const visaTypes = {{ visaTypes | dump | safe }};

  const state = { step: 1, answers: {} };

  window.bcAnswer = function(step, value) {
    if (step === 3 && (!value || isNaN(Number(value)) || Number(value) <= 0)) {
      alert('Please enter a valid salary amount.');
      return;
    }
    if (step === 5 && !value) {
      alert('Please select a country.');
      return;
    }
    state.answers[step] = value;
    if (step < 5) {
      state.step = step + 1;
      renderStep();
    } else {
      showResults();
    }
  };

  window.bcBack = function() {
    if (state.step > 1) {
      state.step--;
      renderStep();
    }
  };

  window.bcRestart = function() {
    state.step = 1;
    state.answers = {};
    document.getElementById('bc-results').classList.add('hidden');
    document.getElementById('bc-results').innerHTML = '';
    document.getElementById('bc-steps').classList.remove('hidden');
    document.getElementById('bc-restart').classList.add('hidden');
    renderStep();
  };

  function renderStep() {
    const steps = document.querySelectorAll('.bc-step');
    steps.forEach(s => s.classList.add('hidden'));
    const current = document.querySelector(`.bc-step[data-step="${state.step}"]`);
    if (current) current.classList.remove('hidden');

    const pct = (state.step / 5) * 100;
    document.getElementById('bc-progress').style.width = pct + '%';
    document.getElementById('bc-step-label').textContent = `Step ${state.step} of 5`;

    const backBtn = document.getElementById('bc-back');
    if (state.step > 1) backBtn.classList.remove('hidden');
    else backBtn.classList.add('hidden');

    if (window.lucide) lucide.createIcons();
  }

  function showResults() {
    document.getElementById('bc-steps').classList.add('hidden');
    document.getElementById('bc-back').classList.add('hidden');
    document.getElementById('bc-restart').classList.remove('hidden');
    document.getElementById('bc-progress').style.width = '100%';
    document.getElementById('bc-step-label').textContent = 'Complete';

    const a = state.answers;
    const salary = Number(a[3]) || 0;
    const isShortage = a[4] === 'yes';
    const threshold = isShortage ? 41042 : 45300;

    const checks = [
      { label: 'University degree or equivalent qualification', met: a[1] === 'yes' || a[1] === 'equivalent', note: a[1] === 'equivalent' ? 'Some countries accept equivalent qualifications — verify with the local authority' : '' },
      { label: 'Job offer in an EU country', met: a[2] === 'yes', note: a[2] === 'notyet' ? 'You can still prepare — start applying to visa-sponsoring companies' : '' },
      { label: `Salary meets threshold (€${threshold.toLocaleString()})`, met: salary >= threshold, note: salary > 0 && salary < threshold ? `Your salary of €${salary.toLocaleString()} is €${(threshold - salary).toLocaleString()} below the threshold` : '' },
      { label: 'Role in shortage occupation (lower threshold)', met: isShortage, note: !isShortage ? 'General threshold of €45,300 applies' : 'Reduced threshold of €41,042 applies' },
    ];

    const metCount = checks.filter(c => c.met).length;
    const hasDegree = a[1] !== 'no';
    const hasOffer = a[2] === 'yes';
    const meetsSalary = salary >= threshold;

    let status, statusColor, statusIcon, statusBg;
    if (hasDegree && hasOffer && meetsSalary) {
      status = 'Likely Eligible';
      statusColor = 'text-green-700 dark:text-green-400';
      statusBg = 'bg-green-50 dark:bg-green-900/20 border-green-200 dark:border-green-800';
      statusIcon = 'check-circle';
    } else if (hasDegree && (hasOffer || a[2] === 'notyet') && (meetsSalary || salary === 0)) {
      status = 'Potentially Eligible';
      statusColor = 'text-amber-700 dark:text-amber-400';
      statusBg = 'bg-amber-50 dark:bg-amber-900/20 border-amber-200 dark:border-amber-800';
      statusIcon = 'alert-circle';
    } else {
      status = 'Not Eligible';
      statusColor = 'text-red-700 dark:text-red-400';
      statusBg = 'bg-red-50 dark:bg-red-900/20 border-red-200 dark:border-red-800';
      statusIcon = 'x-circle';
    }

    let html = `
      <div class="border rounded-xl p-6 mb-6 ${statusBg}">
        <div class="flex items-center gap-3 mb-2">
          <i data-lucide="${statusIcon}" class="w-8 h-8 ${statusColor}"></i>
          <h2 class="text-2xl font-extrabold ${statusColor}">${status}</h2>
        </div>
        <p class="text-sm text-gray-600 dark:text-gray-400">Based on your answers, ${metCount} of 4 key requirements are met.</p>
      </div>
      <h3 class="text-lg font-bold text-gray-900 dark:text-white mb-4">Requirements Breakdown</h3>
      <div class="space-y-3 mb-8">
    `;

    checks.forEach(c => {
      const icon = c.met ? 'check-circle' : 'x-circle';
      const color = c.met ? 'text-green-500' : 'text-red-500';
      html += `
        <div class="flex items-start gap-3 p-3 rounded-lg bg-gray-50 dark:bg-gray-800/50">
          <i data-lucide="${icon}" class="w-5 h-5 ${color} shrink-0 mt-0.5"></i>
          <div>
            <span class="font-medium text-gray-900 dark:text-white text-sm">${c.label}</span>
            ${c.note ? `<p class="text-xs text-gray-500 dark:text-gray-400 mt-0.5">${c.note}</p>` : ''}
          </div>
        </div>
      `;
    });
    html += '</div>';

    if (status !== 'Not Eligible') {
      html += `
        <div class="bg-blue-50 dark:bg-blue-900/20 border-l-4 border-blue-400 p-4 rounded-r-lg mb-6">
          <h4 class="font-semibold text-blue-800 dark:text-blue-300 mb-1">Next Steps</h4>
          <ul class="text-sm text-blue-700 dark:text-blue-400 space-y-1 list-disc list-inside">
            <li>Get your degree <a href="https://anabin.kmk.org/" target="_blank" rel="noopener" class="underline">recognized via anabin</a> (for Germany)</li>
            <li><a href="/visa-sponsored-jobs/" class="underline">Browse visa-sponsoring companies</a> on our job board</li>
            <li>Read the <a href="https://www.make-it-in-germany.com/en/visa-residence/types/eu-blue-card" target="_blank" rel="noopener" class="underline">official EU Blue Card guide</a></li>
            <li>Check the <a href="/resources/country-guides/germany/" class="underline">Germany country guide</a> for detailed info</li>
          </ul>
        </div>
      `;
    }

    if (status === 'Not Eligible') {
      const alternatives = visaTypes.filter(v => v.slug !== 'eu-blue-card' && v.slug !== 'us-h1b');
      html += `
        <div class="bg-yellow-50 dark:bg-yellow-900/20 border-l-4 border-yellow-400 p-4 rounded-r-lg mb-6">
          <h4 class="font-semibold text-yellow-800 dark:text-yellow-300 mb-1">Don't give up — consider these alternatives</h4>
          <p class="text-sm text-yellow-700 dark:text-yellow-400 mb-3">You may qualify for other visa types depending on your situation.</p>
        </div>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4 mb-6">
      `;
      alternatives.slice(0, 4).forEach(v => {
        html += `
          <div class="card p-4">
            <h4 class="font-bold text-gray-900 dark:text-white text-sm mb-1">${v.name}</h4>
            <p class="text-xs text-gray-500 dark:text-gray-400 mb-2">${v.country} · ${v.processingTime}</p>
            <p class="text-xs text-gray-600 dark:text-gray-400 mb-2">Salary: ${v.salaryThreshold}</p>
            <a href="${v.officialUrl}" target="_blank" rel="noopener" class="text-xs text-brand-600 dark:text-brand-400 hover:underline">Learn more &rarr;</a>
          </div>
        `;
      });
      html += '</div>';
      html += `<p class="text-sm text-gray-600 dark:text-gray-400"><a href="/visa-sponsored-jobs/" class="text-brand-600 dark:text-brand-400 hover:underline">Browse all visa-sponsored jobs &rarr;</a></p>`;
    }

    const container = document.getElementById('bc-results');
    container.innerHTML = html;
    container.classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
  }

  renderStep();
})();
</script>
