<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "EU Blue Card Eligibility Checker",
  "url": "{{ site.url }}{{ page.url }}",
  "description": "{{ description }}",
  "applicationCategory": "Utility",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "What is the EU Blue Card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The EU Blue Card is a work and residence permit for highly skilled non-EU citizens. It provides fast-track access to 25 EU member states, allows your spouse to work immediately, and offers a path to permanent residence in as little as 21 months."
      }
    },
    {
      "@type": "Question",
      "name": "What is the salary threshold for the EU Blue Card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The general salary threshold is €45,300 per year. For shortage occupations such as IT, engineering, and medicine, the reduced threshold is €41,042 per year."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a university degree for the EU Blue Card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Yes, you typically need a recognized university degree. However, some EU countries now accept equivalent professional qualifications or extensive work experience (usually 5+ years) in lieu of a formal degree."
      }
    },
    {
      "@type": "Question",
      "name": "How long does EU Blue Card processing take?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Processing typically takes 4-8 weeks from the date of application. Some countries may process faster depending on your nationality and the completeness of your application."
      }
    },
    {
      "@type": "Question",
      "name": "Can I change employers with an EU Blue Card?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "During the first two years, you need approval from the immigration authority to change employers. After two years, you can change jobs freely as long as the new position meets the Blue Card requirements."
      }
    }
  ]
}
</script>
