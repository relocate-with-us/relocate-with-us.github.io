  var tableRows = [
    { key: 'systemType', label: 'System Type', icon: 'building-2' },
    { key: 'insuranceRequired', label: 'Insurance Required?', icon: 'shield-check' },
    { key: 'monthlyCost', label: 'Monthly Cost', icon: 'wallet' },
    { key: 'qualityRating', label: 'Quality Rating', icon: 'star', isRating: true },
    { key: 'whoRank', label: 'WHO Rank', icon: 'trophy', isNumeric: true, sortAsc: true },
    { key: 'gpWait', label: 'GP Wait Time', icon: 'clock' },
    { key: 'specialistWait', label: 'Specialist Wait Time', icon: 'hourglass' },
    { key: 'emergencyQuality', label: 'Emergency Quality', icon: 'siren' },
    { key: 'dentalCoverage', label: 'Dental Coverage', icon: 'smile' },
    { key: 'mentalHealth', label: 'Mental Health Coverage', icon: 'brain' },
    { key: 'prescriptionCosts', label: 'Prescription Costs', icon: 'pill' },
    { key: 'expatFriendly', label: 'Expat-Friendly Rating', icon: 'globe', isRating: true }
  ];

  var activeCountries = {};
  countries.forEach(function(c) { activeCountries[c.id] = true; });

  function renderStars(val, max) {
    max = max || 10;
    var full = Math.floor(val);
    var half = val % 1 >= 0.5;
    var stars = '';
    var scale5 = val / 2;
    var fullStars = Math.floor(scale5);
    var halfStar = scale5 % 1 >= 0.25;
    for (var i = 0; i < 5; i++) {
      if (i < fullStars) stars += '<i data-lucide="star" class="w-3.5 h-3.5 inline rating-star fill-current"></i>';
      else if (i === fullStars && halfStar) stars += '<i data-lucide="star-half" class="w-3.5 h-3.5 inline rating-star fill-current"></i>';
      else stars += '<i data-lucide="star" class="w-3.5 h-3.5 inline rating-empty"></i>';
    }
    return '<span class="inline-flex items-center gap-0.5">' + stars + ' <span class="ml-1 text-gray-600 dark:text-gray-400">' + val + '</span></span>';
  }

  function getActive() {
    return countries.filter(function(c) { return activeCountries[c.id]; });
  }

  function renderToggles() {
    var container = document.getElementById('country-toggles');
    container.innerHTML = '';
    countries.forEach(function(c) {
      var btn = document.createElement('button');
      btn.className = 'country-toggle px-3 py-2 rounded-lg text-sm font-medium border transition-colors ' +
        (activeCountries[c.id]
          ? 'bg-brand-50 dark:bg-brand-900/30 border-brand-300 dark:border-brand-700 text-brand-700 dark:text-brand-300 active'
          : 'bg-white dark:bg-gray-800 border-gray-200 dark:border-gray-700 text-gray-500 dark:text-gray-400');
      btn.textContent = c.emoji + ' ' + c.name;
      btn.addEventListener('click', function() {
        activeCountries[c.id] = !activeCountries[c.id];
        renderToggles();
        renderTable();
      });
      container.appendChild(btn);
    });
  }

  var currentSort = { key: null, asc: true };

  function renderTable() {
    var active = getActive();
    if (active.length === 0) {
      document.getElementById('table-header').innerHTML = '<th class="text-left py-3 px-4 text-gray-500 dark:text-gray-400" colspan="2">Select at least one country to compare</th>';
      document.getElementById('table-body').innerHTML = '';
      return;
    }

    var headerHtml = '<th class="text-left py-3 px-4 font-semibold text-gray-700 dark:text-gray-300 sticky left-0 bg-white dark:bg-gray-800 z-10 min-w-[180px]">Metric</th>';
    active.forEach(function(c) {
      headerHtml += '<th class="text-center py-3 px-4 font-semibold text-gray-700 dark:text-gray-300 min-w-[140px] cursor-pointer hover:text-brand-600 dark:hover:text-brand-400" data-country-detail="' + c.id + '">' +
        '<span class="block text-lg mb-0.5">' + c.emoji + '</span>' + c.name + '</th>';
    });
    document.getElementById('table-header').innerHTML = headerHtml;

    var sortedRows = tableRows.slice();
    if (currentSort.key) {
      sortedRows.sort(function(a, b) { return 0; });
    }

    var bodyHtml = '';
    sortedRows.forEach(function(row, idx) {
      var bgClass = idx % 2 === 0 ? 'bg-gray-50/50 dark:bg-gray-800/30' : '';
      bodyHtml += '<tr class="border-b border-gray-100 dark:border-gray-800 ' + bgClass + ' hover:bg-gray-100/50 dark:hover:bg-gray-800/50">';
      bodyHtml += '<td class="py-3 px-4 font-medium text-gray-700 dark:text-gray-300 sticky left-0 bg-inherit z-10 whitespace-nowrap">' +
        '<span class="inline-flex items-center gap-2"><i data-lucide="' + row.icon + '" class="w-4 h-4 text-gray-400 shrink-0"></i>' + row.label + '</span></td>';

      active.forEach(function(c) {
        var val = c[row.key];
        var cellContent;
        if (row.isRating) {
          cellContent = renderStars(val);
        } else if (row.key === 'whoRank') {
          cellContent = '<span class="badge">#' + val + '</span>';
        } else if (row.key === 'emergencyQuality') {
          var eqColor = val === 'Excellent' ? 'text-emerald-600 dark:text-emerald-400' : 'text-blue-600 dark:text-blue-400';
          cellContent = '<span class="font-medium ' + eqColor + '">' + val + '</span>';
        } else {
          cellContent = '<span class="text-gray-900 dark:text-white">' + val + '</span>';
        }
        bodyHtml += '<td class="py-3 px-4 text-center text-sm">' + cellContent + '</td>';
      });
      bodyHtml += '</tr>';
    });

    document.getElementById('table-body').innerHTML = bodyHtml;

    document.querySelectorAll('[data-country-detail]').forEach(function(th) {
      th.addEventListener('click', function() {
        showDetail(th.getAttribute('data-country-detail'));
      });
    });

    if (window.lucide) lucide.createIcons();
  }

  function renderDetailButtons() {
    var container = document.getElementById('detail-country-btns');
    container.innerHTML = '';
    countries.forEach(function(c) {
      var btn = document.createElement('button');
      btn.className = 'btn-secondary text-xs';
      btn.textContent = c.emoji + ' ' + c.name;
      btn.addEventListener('click', function() { showDetail(c.id); });
      container.appendChild(btn);
    });
  }

  function showDetail(countryId) {
    var c = countries.find(function(x) { return x.id === countryId; });
    if (!c) return;

    var panel = document.getElementById('detail-panel');
    panel.classList.remove('hidden');

    var coveredHtml = c.covered.map(function(item) {
      return '<li class="flex items-start gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500 mt-0.5 shrink-0"></i><span>' + item + '</span></li>';
    }).join('');

    var notCoveredHtml = c.notCovered.map(function(item) {
      return '<li class="flex items-start gap-2"><i data-lucide="x-circle" class="w-4 h-4 text-red-400 mt-0.5 shrink-0"></i><span>' + item + '</span></li>';
    }).join('');

    var tipsHtml = c.tips.map(function(tip) {
      return '<li class="flex items-start gap-2"><i data-lucide="lightbulb" class="w-4 h-4 text-amber-500 mt-0.5 shrink-0"></i><span>' + tip + '</span></li>';
    }).join('');

    var contactsHtml = c.contacts.map(function(contact) {
      return '<li class="flex items-start gap-2"><i data-lucide="link" class="w-4 h-4 text-brand-500 mt-0.5 shrink-0"></i><span>' + contact + '</span></li>';
    }).join('');

    var html = '<div class="lg:col-span-2 detail-card">' +
      '<div class="card p-6 md:p-8">' +
        '<div class="flex items-center gap-3 mb-6">' +
          '<span class="text-4xl">' + c.emoji + '</span>' +
          '<div>' +
            '<h3 class="text-2xl font-bold text-gray-900 dark:text-white">' + c.name + '</h3>' +
            '<p class="text-sm text-gray-500 dark:text-gray-400">' + c.systemType + ' · WHO Rank #' + c.whoRank + '</p>' +
          '</div>' +
        '</div>' +

        '<div class="mb-6">' +
          '<h4 class="font-semibold text-gray-900 dark:text-white mb-2 flex items-center gap-2"><i data-lucide="info" class="w-4 h-4 text-brand-500"></i>How It Works for Expats</h4>' +
          '<p class="text-gray-600 dark:text-gray-400 text-sm leading-relaxed">' + c.howItWorks + '</p>' +
        '</div>' +

        '<div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-6">' +
          '<div>' +
            '<h4 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2"><i data-lucide="check-circle-2" class="w-4 h-4 text-emerald-500"></i>What\'s Covered</h4>' +
            '<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">' + coveredHtml + '</ul>' +
          '</div>' +
          '<div>' +
            '<h4 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2"><i data-lucide="x-circle" class="w-4 h-4 text-red-400"></i>What\'s NOT Covered</h4>' +
            '<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">' + notCoveredHtml + '</ul>' +
          '</div>' +
        '</div>' +

        '<div class="p-4 bg-brand-50 dark:bg-brand-900/20 rounded-xl mb-6">' +
          '<h4 class="font-semibold text-gray-900 dark:text-white mb-1 flex items-center gap-2"><i data-lucide="wallet" class="w-4 h-4 text-brand-500"></i>Estimated Monthly Cost</h4>' +
          '<p class="text-gray-700 dark:text-gray-300 text-sm">' + c.costRange + '</p>' +
        '</div>' +

        '<div class="grid grid-cols-1 md:grid-cols-2 gap-6">' +
          '<div>' +
            '<h4 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2"><i data-lucide="lightbulb" class="w-4 h-4 text-amber-500"></i>Tips for Navigating the System</h4>' +
            '<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">' + tipsHtml + '</ul>' +
          '</div>' +
          '<div>' +
            '<h4 class="font-semibold text-gray-900 dark:text-white mb-3 flex items-center gap-2"><i data-lucide="phone" class="w-4 h-4 text-brand-500"></i>Key Contacts & Resources</h4>' +
            '<ul class="space-y-2 text-sm text-gray-600 dark:text-gray-400">' + contactsHtml + '</ul>' +
          '</div>' +
        '</div>' +
      '</div>' +
    '</div>';

    document.getElementById('detail-grid').innerHTML = html;
    if (window.lucide) lucide.createIcons();

    panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  function updateSummary() {
    var universalCount = countries.filter(function(c) {
      return c.monthlyCost.indexOf('€0') === 0 || c.systemType.toLowerCase().indexOf('tax-funded') !== -1 || c.systemType.toLowerCase().indexOf('universal') !== -1 || c.systemType.indexOf('NHS') !== -1;
    }).length;
    document.getElementById('universal-count').textContent = universalCount + ' of 10';

    var totalQuality = countries.reduce(function(sum, c) { return sum + c.qualityRating; }, 0);
    document.getElementById('avg-quality').textContent = (totalQuality / countries.length).toFixed(1) + '/10';
  }

  document.getElementById('select-all-btn').addEventListener('click', function() {
    countries.forEach(function(c) { activeCountries[c.id] = true; });
    renderToggles();
    renderTable();
  });

  document.getElementById('clear-all-btn').addEventListener('click', function() {
    countries.forEach(function(c) { activeCountries[c.id] = false; });
    renderToggles();
    renderTable();
  });

  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });

  updateSummary();
  renderToggles();
  renderTable();
  renderDetailButtons();
})();
</script>
{% endblock %}
