{% block scripts %}
<script>
(function() {
  var companies = {{ companies | jsonify | safe }};
  var searchInput = document.getElementById('company-search');
  var resultsSection = document.getElementById('search-results');
  var resultsContainer = document.getElementById('results-container');
  var resultsCount = document.getElementById('results-count');
  var noResults = document.getElementById('no-results');

  function renderCompanyCard(c) {
    var countriesHtml = c.countries.map(function(country) {
      return '<span class="text-xs px-2 py-0.5 rounded-full bg-brand-50 dark:bg-brand-900/20 text-brand-700 dark:text-brand-300 border border-brand-200 dark:border-brand-800">' + country + '</span>';
    }).join('');

    var visaHtml = c.visaTypes.map(function(v) {
      return '<span class="text-xs px-2 py-0.5 rounded-full bg-gray-100 dark:bg-gray-800 text-gray-600 dark:text-gray-400">' + v + '</span>';
    }).join('');

    var relocHtml = '';
    if (c.relocation && c.relocationDetails) {
      relocHtml = '<div class="mt-3 p-3 bg-green-50 dark:bg-green-900/20 rounded-lg border border-green-200 dark:border-green-800">' +
        '<p class="text-sm text-green-800 dark:text-green-300 flex items-start gap-2">' +
        '<i data-lucide="package" class="w-4 h-4 shrink-0 mt-0.5"></i>' +
        '<span><strong>Relocation:</strong> ' + c.relocationDetails + '</span></p></div>';
    }

    return '<div class="card p-6">' +
      '<div class="flex items-start justify-between mb-2">' +
        '<div><h3 class="text-xl font-semibold text-gray-900 dark:text-white">' + c.name + '</h3>' +
        '<p class="text-sm text-gray-500 dark:text-gray-400 mt-0.5">' + c.hq + ' &middot; ' + c.industry + ' &middot; ' + c.size + ' employees</p></div>' +
        '<span class="badge badge-visa shrink-0"><i data-lucide="check-circle" class="w-3.5 h-3.5 mr-1"></i>Verified</span>' +
      '</div>' +
      '<div class="flex flex-wrap gap-1.5 mt-3"><strong class="text-xs text-gray-500 dark:text-gray-400 mr-1">Countries:</strong>' + countriesHtml + '</div>' +
      '<div class="flex flex-wrap gap-1.5 mt-2"><strong class="text-xs text-gray-500 dark:text-gray-400 mr-1">Visa Types:</strong>' + visaHtml + '</div>' +
      relocHtml +
      (c.notes ? '<p class="text-sm text-gray-600 dark:text-gray-400 mt-3">' + c.notes + '</p>' : '') +
      '<div class="mt-4 flex items-center gap-4">' +
        '<a href="' + c.careers + '" target="_blank" rel="noopener" class="btn-primary text-sm">View Careers <i data-lucide="external-link" class="w-3.5 h-3.5 ml-1"></i></a>' +
        '<a href="/visa-sponsored-jobs/" class="text-sm text-brand-600 dark:text-brand-400 hover:underline">See open jobs</a>' +
      '</div>' +
    '</div>';
  }

  function doSearch(query) {
    query = query.trim().toLowerCase();
    if (query.length < 2) {
      resultsSection.classList.add('hidden');
      noResults.classList.add('hidden');
      return;
    }

    var matches = companies.filter(function(c) {
      return c.name.toLowerCase().indexOf(query) !== -1 ||
             c.industry.toLowerCase().indexOf(query) !== -1 ||
             c.hq.toLowerCase().indexOf(query) !== -1 ||
             c.countries.some(function(co) { return co.toLowerCase().indexOf(query) !== -1; });
    });

    if (matches.length > 0) {
      resultsCount.textContent = matches.length;
      resultsContainer.innerHTML = matches.map(renderCompanyCard).join('');
      resultsSection.classList.remove('hidden');
      noResults.classList.add('hidden');
      if (window.lucide) lucide.createIcons();
    } else {
      resultsSection.classList.add('hidden');
      noResults.classList.remove('hidden');
      if (window.lucide) lucide.createIcons();
    }
  }

  searchInput.addEventListener('input', debounce(function() {
    doSearch(searchInput.value);
  }, 250));

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
{% endblock %}
