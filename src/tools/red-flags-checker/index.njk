        Job Posting <span class="bg-red-200 dark:bg-red-500/20 dark:text-red-300 px-2 inline-block -skew-x-1">Red Flags</span> Checker
      </h1>
      <p class="text-lg text-gray-600 dark:text-gray-400 max-w-2xl mx-auto mb-8">
        Paste any job description below and we'll instantly scan it for red flags, scam indicators, and positive signals to help you make safer decisions.
      </p>
    </div>
  </div>
</section>

<section class="py-12">
  <div class="max-w-4xl mx-auto px-4">
    <div class="card p-6 md:p-8 mb-8">
      <h2 class="text-xl font-bold text-gray-900 dark:text-white mb-4 flex items-center gap-2">
        <i data-lucide="scan-text" class="w-5 h-5 text-brand-500"></i>
        Paste Job Description
      </h2>
      <textarea id="job-input" class="input-field min-h-[200px] resize-y" placeholder="Paste the full job posting text here…&#10;&#10;Include the job title, company name, description, requirements, benefits, and any visa/relocation information."></textarea>
      <div class="flex items-center justify-between mt-4">
        <span id="char-count" class="text-sm text-gray-400">0 characters</span>
        <div class="flex gap-3">
          <button id="clear-btn" class="btn-secondary text-sm">
            <i data-lucide="eraser" class="w-4 h-4 mr-1"></i> Clear
          </button>
          <button id="analyze-btn" class="btn-primary">
            <i data-lucide="scan" class="w-5 h-5 mr-2"></i> Analyze Job Posting
          </button>
        </div>
      </div>
    </div>

    <div id="results-section" class="hidden space-y-6">
      <div id="score-card" class="card p-6 md:p-8">
        <div class="flex flex-col sm:flex-row sm:items-center gap-4 mb-6">
          <div id="score-icon" class="w-16 h-16 rounded-2xl flex items-center justify-center shrink-0"></div>
          <div>
