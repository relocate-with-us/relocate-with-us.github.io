            <p id="score-subtitle" class="text-gray-600 dark:text-gray-400 mt-1"></p>
          </div>
        </div>
        <div id="score-summary" class="flex flex-wrap gap-4"></div>
      </div>

      <div id="danger-section" class="hidden">
        <h3 class="flex items-center gap-2 text-lg font-bold text-red-600 dark:text-red-400 mb-4">
          <i data-lucide="alert-octagon" class="w-5 h-5"></i> Danger Signs
        </h3>
        <div id="danger-list" class="space-y-3"></div>
