{% block scripts %}
<script>
(function() {
  var visaData = {{ visaTypes | jsonify | safe }};

  var rows = document.querySelectorAll('.visa-row');
  var filterCountry = document.getElementById('filter-country');
  var filterSpeed = document.getElementById('filter-speed');
  var filterSpouse = document.getElementById('filter-spouse');
  var clearFiltersBtn = document.getElementById('clear-filters');
  var compareBar = document.getElementById('compare-bar');
  var compareCountEl = document.getElementById('compare-count');
  var comparePanel = document.getElementById('compare-panel');
  var compareContent = document.getElementById('compare-content');
  var selected = {};

  function getProcessingWeeks(str) {
    var m = str.match(/(\d+)/);
    if (!m) return 99;
    var n = parseInt(m[1]);
    if (str.indexOf('month') !== -1) return n * 4;
    if (str.indexOf('day') !== -1) return Math.ceil(n / 7);
    return n;
  }

  function classifySpeed(str) {
    var weeks = getProcessingWeeks(str);
    if (weeks <= 4) return 'fast';
    if (weeks <= 8) return 'medium';
    return 'slow';
  }

  function classifySpouse(str) {
    var lower = str.toLowerCase();
    if (lower.indexOf('unrestricted') !== -1 || lower.indexOf('full work') !== -1 || lower.indexOf('automatic') !== -1 || lower.indexOf('open work') !== -1) return 'yes';
    return 'limited';
  }

  function applyFilters() {
    var country = filterCountry.value;
    var speed = filterSpeed.value;
    var spouse = filterSpouse.value;
    var anyActive = country || speed || spouse;
    clearFiltersBtn.classList.toggle('hidden', !anyActive);

    rows.forEach(function(row) {
      var show = true;
      if (country && row.getAttribute('data-country') !== country) show = false;
      if (speed && classifySpeed(row.getAttribute('data-processing')) !== speed) show = false;
      if (spouse && classifySpouse(row.getAttribute('data-spouse')) !== spouse) show = false;

      row.classList.toggle('hidden', !show);
      var detail = document.querySelector('tr[data-detail="' + row.getAttribute('data-slug') + '"]');
      if (!show && detail) detail.classList.add('hidden');
    });
  }

  filterCountry.addEventListener('change', applyFilters);
  filterSpeed.addEventListener('change', applyFilters);
  filterSpouse.addEventListener('change', applyFilters);
  clearFiltersBtn.addEventListener('click', function() {
    filterCountry.value = '';
    filterSpeed.value = '';
    filterSpouse.value = '';
    applyFilters();
  });

  // Sorting
  var sortState = { col: null, asc: true };
  document.querySelectorAll('.sortable').forEach(function(th) {
    th.addEventListener('click', function() {
      var col = this.getAttribute('data-sort');
      if (sortState.col === col) {
        sortState.asc = !sortState.asc;
      } else {
        sortState.col = col;
        sortState.asc = true;
      }
      sortTable(col, sortState.asc);
    });
  });

  function sortTable(col, asc) {
    var tbody = document.getElementById('visa-tbody');
    var pairs = [];
    rows.forEach(function(row) {
      var detail = document.querySelector('tr[data-detail="' + row.getAttribute('data-slug') + '"]');
      pairs.push({ row: row, detail: detail });
    });

    pairs.sort(function(a, b) {
      var va, vb;
      if (col === 'name') {
        va = a.row.querySelector('td:nth-child(2)').textContent.trim().toLowerCase();
        vb = b.row.querySelector('td:nth-child(2)').textContent.trim().toLowerCase();
      } else if (col === 'country') {
        va = a.row.getAttribute('data-country').toLowerCase();
        vb = b.row.getAttribute('data-country').toLowerCase();
      } else if (col === 'processing') {
        va = getProcessingWeeks(a.row.getAttribute('data-processing'));
        vb = getProcessingWeeks(b.row.getAttribute('data-processing'));
      } else if (col === 'salary') {
        va = a.row.getAttribute('data-salary').toLowerCase();
        vb = b.row.getAttribute('data-salary').toLowerCase();
      }
      if (va < vb) return asc ? -1 : 1;
      if (va > vb) return asc ? 1 : -1;
      return 0;
    });

    pairs.forEach(function(p) {
      tbody.appendChild(p.row);
      if (p.detail) tbody.appendChild(p.detail);
    });
  }

  // Expand rows
  document.querySelectorAll('.expand-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var slug = this.getAttribute('data-slug');
      var detail = document.querySelector('tr[data-detail="' + slug + '"]');
      var icon = this.querySelector('.expand-icon');
      var isOpen = !detail.classList.contains('hidden');
      detail.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      if (!isOpen && window.lucide) lucide.createIcons();
    });
  });

  // Compare mode
  document.querySelectorAll('.compare-check').forEach(function(cb) {
    cb.addEventListener('change', function() {
      var slug = this.getAttribute('data-slug');
      if (this.checked) {
        if (Object.keys(selected).length >= 3) {
          this.checked = false;
          return;
        }
        selected[slug] = true;
      } else {
        delete selected[slug];
      }
      var count = Object.keys(selected).length;
      compareCountEl.textContent = count;
      compareBar.classList.toggle('hidden', count === 0);
    });
  });

  document.getElementById('clear-compare').addEventListener('click', function() {
    selected = {};
    document.querySelectorAll('.compare-check').forEach(function(cb) { cb.checked = false; });
    compareBar.classList.add('hidden');
    comparePanel.classList.add('hidden');
  });

  document.getElementById('close-compare').addEventListener('click', function() {
    comparePanel.classList.add('hidden');
  });

  document.getElementById('compare-btn').addEventListener('click', function() {
    var slugs = Object.keys(selected);
    if (slugs.length < 2) return;
    var visas = slugs.map(function(s) {
      for (var i = 0; i < visaData.length; i++) {
        if (visaData[i].slug === s) return visaData[i];
      }
      return null;
    }).filter(Boolean);

    var fields = [
      { key: 'country', label: 'Country', icon: 'map-pin' },
      { key: 'processingTime', label: 'Processing Time', icon: 'clock' },
      { key: 'validity', label: 'Validity', icon: 'calendar' },
      { key: 'salaryThreshold', label: 'Salary Threshold', icon: 'banknote' },
      { key: 'spouseWork', label: 'Spouse Work Rights', icon: 'users' },
      { key: 'pathToPR', label: 'Path to PR', icon: 'flag' },
      { key: 'lottery', label: 'Lottery Required', icon: 'dice-1' }
    ];

    var html = '<table class="w-full text-left text-sm">';
    html += '<thead><tr><th class="p-3 font-semibold text-gray-500 dark:text-gray-400"></th>';
    visas.forEach(function(v) {
      html += '<th class="p-3 font-bold text-gray-900 dark:text-white">' + v.name + '</th>';
    });
    html += '</tr></thead><tbody>';

    fields.forEach(function(f) {
      html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
      html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="' + f.icon + '" class="w-4 h-4 inline mr-2 text-gray-400"></i>' + f.label + '</td>';
      visas.forEach(function(v) {
        var val = v[f.key];
        if (f.key === 'lottery') val = val ? '<span class="text-red-600 dark:text-red-400 font-semibold">Yes</span>' : '<span class="text-emerald-600 dark:text-emerald-400 font-semibold">No</span>';
        html += '<td class="p-3 text-gray-600 dark:text-gray-400">' + val + '</td>';
      });
      html += '</tr>';
    });

    html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
    html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="thumbs-up" class="w-4 h-4 inline mr-2 text-emerald-500"></i>Key Pros</td>';
    visas.forEach(function(v) {
      html += '<td class="p-3"><ul class="space-y-1">';
      v.pros.forEach(function(p) {
        html += '<li class="text-gray-600 dark:text-gray-400 flex items-start gap-1"><i data-lucide="plus" class="w-3 h-3 text-emerald-500 shrink-0 mt-0.5"></i>' + p + '</li>';
      });
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
    html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="thumbs-down" class="w-4 h-4 inline mr-2 text-red-500"></i>Key Cons</td>';
    visas.forEach(function(v) {
      html += '<td class="p-3"><ul class="space-y-1">';
      v.cons.forEach(function(c) {
        html += '<li class="text-gray-600 dark:text-gray-400 flex items-start gap-1"><i data-lucide="minus" class="w-3 h-3 text-red-500 shrink-0 mt-0.5"></i>' + c + '</li>';
      });
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '</tbody></table>';

    compareContent.innerHTML = html;
    comparePanel.classList.remove('hidden');
    window.scrollTo({ top: comparePanel.offsetTop - 100, behavior: 'smooth' });
    if (window.lucide) lucide.createIcons();
  });

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
{% endblock %}
