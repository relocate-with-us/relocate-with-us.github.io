{% block scripts %}
<script>
(function() {
  var cities = {{ costOfLiving.cities | jsonify | safe }};
  var cityMap = {};
  cities.forEach(function(c) { cityMap[c.slug] = c; });

  var categories = [
    { key: 'rent1bed', label: 'Rent (1-bed apartment)', icon: 'home' },
    { key: 'rent3bed', label: 'Rent (3-bed apartment)', icon: 'building' },
    { key: 'groceries', label: 'Groceries (monthly)', icon: 'shopping-cart' },
    { key: 'transport', label: 'Public Transport (monthly pass)', icon: 'train-front' },
    { key: 'utilities', label: 'Utilities (monthly)', icon: 'zap' },
    { key: 'internet', label: 'Internet', icon: 'wifi' },
    { key: 'gym', label: 'Gym membership', icon: 'dumbbell' },
    { key: 'coffee', label: 'Coffee (cappuccino)', icon: 'coffee' },
    { key: 'meal', label: 'Lunch (casual restaurant)', icon: 'utensils' },
    { key: 'restaurant', label: 'Dinner for two (mid-range)', icon: 'utensils-crossed' },
    { key: 'beer', label: 'Beer (0.5l draught)', icon: 'beer' }
  ];

  function monthlyTotal(city) {
    return city.rent1bed + city.groceries + city.transport + city.utilities + city.internet;
  }

  function diffPct(a, b) {
    if (b === 0) return 0;
    return ((a - b) / b * 100);
  }

  function diffLabel(a, b, catLabel, cityAName, cityBName) {
    var pct = diffPct(a, b);
    if (Math.abs(pct) < 1) return '<span class="text-gray-500 dark:text-gray-400">Similar</span>';
    var cls = pct > 0 ? 'diff-negative' : 'diff-positive';
    var dir = pct > 0 ? 'more' : 'less';
    return '<span class="' + cls + ' font-medium">' + Math.abs(Math.round(pct)) + '% ' + dir + '</span>';
  }

  document.getElementById('compare-btn').addEventListener('click', function() {
    var slugA = document.getElementById('city-a').value;
    var slugB = document.getElementById('city-b').value;
    if (!slugA || !slugB || slugA === slugB) return;

    var a = cityMap[slugA];
    var b = cityMap[slugB];
    if (!a || !b) return;

    var totalA = monthlyTotal(a);
    var totalB = monthlyTotal(b);

    document.getElementById('total-a').textContent = '€' + totalA.toLocaleString();
    document.getElementById('total-b').textContent = '€' + totalB.toLocaleString();
    document.getElementById('name-a').textContent = a.name;
    document.getElementById('name-b').textContent = b.name;
    document.getElementById('th-a').textContent = a.name;
    document.getElementById('th-b').textContent = b.name;

    var totalDiff = diffPct(totalA, totalB);
    var diffEl = document.getElementById('total-diff');
    if (Math.abs(totalDiff) < 1) {
      diffEl.textContent = 'Similar costs';
      diffEl.className = 'text-2xl font-bold text-gray-500';
    } else {
      var cheaper = totalA < totalB ? a.name : b.name;
      diffEl.innerHTML = '<span class="' + (totalA < totalB ? 'diff-positive' : 'diff-negative') + '">' + Math.abs(Math.round(totalDiff)) + '%</span>';
      diffEl.className = 'text-2xl font-bold';
    }

    // Visual bars
    var maxTotal = Math.max(totalA, totalB);
    var maxH = 160;
    document.getElementById('vis-bar-a').style.height = (totalA / maxTotal * maxH) + 'px';
    document.getElementById('vis-bar-b').style.height = (totalB / maxTotal * maxH) + 'px';
    document.getElementById('vis-name-a').textContent = a.name + ' (€' + totalA.toLocaleString() + ')';
    document.getElementById('vis-name-b').textContent = b.name + ' (€' + totalB.toLocaleString() + ')';

    // Category breakdown table
    var tbody = document.getElementById('comparison-tbody');
    var rows = '';
    categories.forEach(function(cat) {
      var valA = a[cat.key];
      var valB = b[cat.key];
      var diff = diffLabel(valA, valB, cat.label, a.name, b.name);
      rows += '<tr class="border-b border-gray-100 dark:border-gray-800">' +
        '<td class="py-3 px-4 text-gray-700 dark:text-gray-300 flex items-center gap-2"><i data-lucide="' + cat.icon + '" class="w-4 h-4 text-gray-400"></i>' + cat.label + '</td>' +
        '<td class="py-3 px-4 text-right font-medium text-gray-900 dark:text-white">€' + valA.toLocaleString() + '</td>' +
        '<td class="py-3 px-4 text-right font-medium text-gray-900 dark:text-white">€' + valB.toLocaleString() + '</td>' +
        '<td class="py-3 px-4 text-right">' + diff + '</td>' +
      '</tr>';
    });

    rows += '<tr class="border-t-2 border-gray-300 dark:border-gray-600 font-semibold">' +
      '<td class="py-3 px-4 text-gray-900 dark:text-white">Monthly Total (essentials)</td>' +
      '<td class="py-3 px-4 text-right text-gray-900 dark:text-white">€' + totalA.toLocaleString() + '</td>' +
      '<td class="py-3 px-4 text-right text-gray-900 dark:text-white">€' + totalB.toLocaleString() + '</td>' +
      '<td class="py-3 px-4 text-right">' + diffLabel(totalA, totalB) + '</td>' +
    '</tr>';

    tbody.innerHTML = rows;
    document.getElementById('comparison-result').classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
  });

  // Table sorting
  var table = document.getElementById('cities-table');
  var sortHeaders = table.querySelectorAll('th[data-sort]');
  var sortDir = {};

  sortHeaders.forEach(function(th) {
    th.addEventListener('click', function() {
      var key = th.getAttribute('data-sort');
      sortDir[key] = !sortDir[key];
      var tbody = table.querySelector('tbody');
      var rows = Array.from(tbody.querySelectorAll('tr'));
      rows.sort(function(a, b) {
        var aVal, bVal;
        if (key === 'name') {
          aVal = a.getAttribute('data-name');
          bVal = b.getAttribute('data-name');
          return sortDir[key] ? aVal.localeCompare(bVal) : bVal.localeCompare(aVal);
        }
        aVal = parseFloat(a.getAttribute('data-' + key));
        bVal = parseFloat(b.getAttribute('data-' + key));
        return sortDir[key] ? aVal - bVal : bVal - aVal;
      });
      rows.forEach(function(row) { tbody.appendChild(row); });
    });
  });

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
{% endblock %}
