{# Comparison Tool #}
<section class="py-12">
  <div class="max-w-5xl mx-auto px-4">
    <div class="card p-6 md:p-8">
      <h2 class="text-xl font-semibold text-gray-900 dark:text-white mb-6">Compare Two Cities</h2>

      <div class="grid grid-cols-1 md:grid-cols-3 gap-4 mb-6">
        <div>
          <label for="city-a" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">City A</label>
          <select id="city-a" class="input-field">
            <option value="">Select a city</option>
            {% for city in costOfLiving.cities %}
            <option value="{{ city.slug }}">{{ city.emoji }} {{ city.name }}, {{ city.country }}</option>
            {% endfor %}
          </select>
        </div>
        <div>
          <label for="city-b" class="block text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">City B</label>
          <select id="city-b" class="input-field">
            <option value="">Select a city</option>
            {% for city in costOfLiving.cities %}
            <option value="{{ city.slug }}">{{ city.emoji }} {{ city.name }}, {{ city.country }}</option>
            {% endfor %}
          </select>
        </div>
        <div class="flex items-end">
          <button id="compare-btn" class="btn-primary w-full">
            <i data-lucide="bar-chart-3" class="w-4 h-4 mr-2"></i>Compare
          </button>
        </div>
      </div>

      {# Comparison Results #}
      <div id="comparison-result" class="hidden">
        <div class="border-t border-gray-200 dark:border-gray-700 pt-6">
          <div class="grid grid-cols-3 gap-4 mb-6 text-center">
            <div class="p-4 bg-brand-50 dark:bg-brand-900/20 rounded-xl">
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Monthly Total</p>
              <p class="text-xl font-bold text-gray-900 dark:text-white" id="total-a">-</p>
              <p class="text-sm text-gray-500 dark:text-gray-400" id="name-a">-</p>
            </div>
            <div class="flex items-center justify-center">
              <div class="text-center">
                <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Difference</p>
                <p class="text-2xl font-bold" id="total-diff">-</p>
              </div>
            </div>
            <div class="p-4 bg-brand-50 dark:bg-brand-900/20 rounded-xl">
              <p class="text-sm text-gray-500 dark:text-gray-400 mb-1">Monthly Total</p>
              <p class="text-xl font-bold text-gray-900 dark:text-white" id="total-b">-</p>
              <p class="text-sm text-gray-500 dark:text-gray-400" id="name-b">-</p>
            </div>
          </div>

          {# Monthly bar comparison #}
          <div class="mb-8">
            <h3 class="text-sm font-semibold text-gray-700 dark:text-gray-300 mb-4">Monthly Cost Comparison</h3>
            <div class="flex items-end gap-6 justify-center h-48">
              <div class="flex flex-col items-center">
                <div id="vis-bar-a" class="w-24 bg-brand-500 rounded-t-lg transition-all duration-500" style="height:0px"></div>
                <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2" id="vis-name-a">-</p>
              </div>
              <div class="flex flex-col items-center">
                <div id="vis-bar-b" class="w-24 bg-purple-500 rounded-t-lg transition-all duration-500" style="height:0px"></div>
                <p class="text-sm font-medium text-gray-700 dark:text-gray-300 mt-2" id="vis-name-b">-</p>
              </div>
            </div>
          </div>

          {# Category Table #}
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead>
                <tr class="border-b border-gray-200 dark:border-gray-700">
                  <th class="text-left py-3 px-4 font-semibold text-gray-700 dark:text-gray-300">Category</th>
                  <th class="text-right py-3 px-4 font-semibold text-gray-700 dark:text-gray-300" id="th-a">City A</th>
                  <th class="text-right py-3 px-4 font-semibold text-gray-700 dark:text-gray-300" id="th-b">City B</th>
                  <th class="text-right py-3 px-4 font-semibold text-gray-700 dark:text-gray-300">Difference</th>
                </tr>
              </thead>
              <tbody id="comparison-tbody"></tbody>
            </table>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

