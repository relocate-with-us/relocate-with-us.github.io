---
layout: layouts/base.njk
title: "Visa Processing Time Tracker | How Long Does a Work Visa Take?"
description: "Check current visa processing times for work permits worldwide. Compare processing times for EU Blue Card, UK Skilled Worker Visa, and more."
---

{% block structuredData %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Visa Processing Time Tracker",
  "url": "{{ site.url }}{{ page.url }}",
  "description": "{{ description }}",
  "applicationCategory": "Utility",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which work visa has the fastest processing time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The Canada Global Talent Stream targets a 2-week processing time, making it the fastest work visa. The Netherlands HSM Visa (2-4 weeks) and France Passeport Talent (2-6 weeks) are also very fast options."
      }
    },
    {
      "@type": "Question",
      "name": "How long does an EU Blue Card take to process?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "The EU Blue Card typically takes 4-8 weeks to process from the date of application. Processing times may vary by country and the completeness of your application."
      }
    },
    {
      "@type": "Question",
      "name": "Can I speed up my visa processing?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Some visas offer premium processing for a fee. For example, the US H-1B offers premium processing with a 15-day turnaround. For other visas, ensuring your application is complete and all documents are properly prepared is the best way to avoid delays."
      }
    },
    {
      "@type": "Question",
      "name": "What factors affect visa processing time?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Processing times are affected by the completeness of your application, your nationality, the country's current processing backlog, whether additional security checks are required, and the time of year (some periods are busier than others)."
      }
    }
  ]
}
</script>
{% endblock %}

<section class="bg-gradient-to-b from-purple-50 to-white dark:from-gray-900 dark:to-gray-950 py-16">
  <div class="max-w-6xl mx-auto px-4">
    <nav class="flex items-center gap-2 text-sm text-gray-500 dark:text-gray-400 mb-6">
      <a href="/" class="hover:text-brand-600 dark:hover:text-brand-400">Home</a>
      <i data-lucide="chevron-right" class="w-4 h-4"></i>
      <a href="/tools/" class="hover:text-brand-600 dark:hover:text-brand-400">Tools</a>
      <i data-lucide="chevron-right" class="w-4 h-4"></i>
      <span class="text-gray-900 dark:text-white">Visa Processing Tracker</span>
    </nav>
    <div class="flex items-center gap-3 mb-4">
      <div class="w-14 h-14 bg-purple-100 dark:bg-purple-900/40 rounded-2xl flex items-center justify-center">
        <i data-lucide="timer" class="w-7 h-7 text-purple-600 dark:text-purple-400"></i>
      </div>
      <h1 class="text-3xl md:text-4xl font-extrabold text-gray-900 dark:text-white">Visa Processing Time Tracker</h1>
    </div>
    <p class="text-lg text-gray-600 dark:text-gray-400 max-w-3xl">
      Compare processing times for work visas worldwide. Sort, filter, and compare side-by-side to plan your timeline.
    </p>
  </div>
</section>

{# Server-rendered summary cards #}
<section class="py-8">
  <div class="max-w-6xl mx-auto px-4">
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-8">
      <div class="card p-4 text-center">
        <p class="text-2xl font-extrabold text-green-600 dark:text-green-400">2 wks</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Fastest (Canada GTS)</p>
      </div>
      <div class="card p-4 text-center">
        <p class="text-2xl font-extrabold text-amber-600 dark:text-amber-400">6 mo</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Slowest (US H-1B)</p>
      </div>
      <div class="card p-4 text-center">
        <p class="text-2xl font-extrabold text-blue-600 dark:text-blue-400">{{ visaTypes | length }}</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Visa types tracked</p>
      </div>
      <div class="card p-4 text-center">
        <p class="text-2xl font-extrabold text-purple-600 dark:text-purple-400">9</p>
        <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">Countries covered</p>
      </div>
    </div>
  </div>
</section>

<section class="pb-16">
  <div class="max-w-6xl mx-auto px-4">

    {# Controls #}
    <div class="flex flex-col sm:flex-row gap-4 mb-8">
      <div class="flex-1">
        <label for="vt-filter" class="block text-sm font-semibold text-gray-900 dark:text-white mb-1">Filter by country</label>
        <select id="vt-filter" class="input-field">
          <option value="">All countries</option>
          {% for visa in visaTypes %}
          <option value="{{ visa.country }}">{{ visa.country }}</option>
          {% endfor %}
        </select>
      </div>
      <div class="flex-1">
        <label for="vt-sort" class="block text-sm font-semibold text-gray-900 dark:text-white mb-1">Sort by</label>
        <select id="vt-sort" class="input-field">
          <option value="fastest">Fastest first</option>
          <option value="slowest">Slowest first</option>
          <option value="name">Name (A–Z)</option>
        </select>
      </div>
      <div class="flex items-end">
        <button id="vt-compare-btn" onclick="vtToggleCompare()" class="btn-secondary text-sm whitespace-nowrap" disabled>
          <i data-lucide="columns-2" class="w-4 h-4 mr-1 inline"></i> Compare (<span id="vt-compare-count">0</span>)
        </button>
      </div>
    </div>

    {# Visa cards #}
    <div id="vt-list" class="space-y-4">
      {% for visa in visaTypes %}
      <div class="vt-card card p-0 overflow-hidden" data-slug="{{ visa.slug }}" data-country="{{ visa.country }}" data-processing="{{ visa.processingTime }}">
        <div class="p-5 cursor-pointer" onclick="vtToggle('{{ visa.slug }}')">
          <div class="flex flex-col sm:flex-row sm:items-center gap-4">
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap mb-1">
                <h3 class="text-lg font-bold text-gray-900 dark:text-white">{{ visa.name }}</h3>
                <span class="vt-speed-badge badge text-xs" data-speed="{{ visa.processingTime }}"></span>
              </div>
              <p class="text-sm text-gray-500 dark:text-gray-400">{{ visa.country }} · {{ visa.category }}</p>
            </div>
            <div class="flex items-center gap-4 sm:gap-6">
              <div class="text-center">
                <p class="text-lg font-extrabold text-gray-900 dark:text-white">{{ visa.processingTime }}</p>
                <p class="text-xs text-gray-500 dark:text-gray-400">Processing</p>
              </div>
              <div class="w-32 sm:w-48">
                <div class="w-full bg-gray-200 dark:bg-gray-700 rounded-full h-3">
                  <div class="vt-bar h-3 rounded-full transition-all" data-time="{{ visa.processingTime }}"></div>
                </div>
              </div>
              <div class="flex items-center gap-2">
                <label class="flex items-center gap-1 text-xs text-gray-500 dark:text-gray-400 cursor-pointer" onclick="event.stopPropagation()">
                  <input type="checkbox" class="vt-compare-check rounded border-gray-300 dark:border-gray-600 text-brand-600 focus:ring-brand-500" data-slug="{{ visa.slug }}" onchange="vtUpdateCompare()" />
                  Compare
                </label>
                <i data-lucide="chevron-down" class="w-5 h-5 text-gray-400 transition-transform vt-chevron" id="vt-chevron-{{ visa.slug }}"></i>
              </div>
            </div>
          </div>
        </div>
        <div class="vt-details hidden border-t border-gray-200 dark:border-gray-700 bg-gray-50 dark:bg-gray-800/50 p-5" id="vt-details-{{ visa.slug }}">
          <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
            <div>
              <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-3">Requirements</h4>
              <ul class="space-y-2">
                {% for req in visa.requirements %}
                <li class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <i data-lucide="check-circle" class="w-4 h-4 text-green-500 shrink-0 mt-0.5"></i>
                  {{ req }}
                </li>
                {% endfor %}
              </ul>
              <div class="mt-4 space-y-2">
                <div class="flex items-center gap-2 text-sm">
                  <i data-lucide="coins" class="w-4 h-4 text-amber-500"></i>
                  <span class="text-gray-600 dark:text-gray-400"><strong class="text-gray-900 dark:text-white">Salary:</strong> {{ visa.salaryThreshold }}</span>
                </div>
                <div class="flex items-center gap-2 text-sm">
                  <i data-lucide="calendar" class="w-4 h-4 text-blue-500"></i>
                  <span class="text-gray-600 dark:text-gray-400"><strong class="text-gray-900 dark:text-white">Validity:</strong> {{ visa.validity }}</span>
                </div>
                <div class="flex items-center gap-2 text-sm">
                  <i data-lucide="users" class="w-4 h-4 text-purple-500"></i>
                  <span class="text-gray-600 dark:text-gray-400"><strong class="text-gray-900 dark:text-white">Spouse work:</strong> {{ visa.spouseWork }}</span>
                </div>
                <div class="flex items-center gap-2 text-sm">
                  <i data-lucide="flag" class="w-4 h-4 text-green-500"></i>
                  <span class="text-gray-600 dark:text-gray-400"><strong class="text-gray-900 dark:text-white">Path to PR:</strong> {{ visa.pathToPR }}</span>
                </div>
              </div>
            </div>
            <div>
              <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-3">Pros & Cons</h4>
              <div class="space-y-2 mb-4">
                {% for pro in visa.pros %}
                <div class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <i data-lucide="plus-circle" class="w-4 h-4 text-green-500 shrink-0 mt-0.5"></i>
                  {{ pro }}
                </div>
                {% endfor %}
              </div>
              <div class="space-y-2 mb-4">
                {% for con in visa.cons %}
                <div class="flex items-start gap-2 text-sm text-gray-600 dark:text-gray-400">
                  <i data-lucide="minus-circle" class="w-4 h-4 text-red-500 shrink-0 mt-0.5"></i>
                  {{ con }}
                </div>
                {% endfor %}
              </div>
              <div class="flex flex-wrap gap-2 mt-4">
                <a href="{{ visa.officialUrl }}" target="_blank" rel="noopener" class="btn-primary text-xs">
                  <i data-lucide="external-link" class="w-3.5 h-3.5 mr-1 inline"></i> Official Page
                </a>
                <a href="/visa-sponsored-jobs/" class="btn-secondary text-xs">
                  <i data-lucide="briefcase" class="w-3.5 h-3.5 mr-1 inline"></i> Find Jobs
                </a>
              </div>
            </div>
          </div>
          {# Timeline steps #}
          <div class="mt-6 pt-6 border-t border-gray-200 dark:border-gray-700">
            <h4 class="text-sm font-bold text-gray-900 dark:text-white mb-4">Typical Process Timeline</h4>
            <div class="flex flex-wrap gap-2">
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-xs font-bold text-brand-600 dark:text-brand-400">1</div>
                <span class="text-xs text-gray-600 dark:text-gray-400">Get job offer</span>
                <i data-lucide="arrow-right" class="w-3 h-3 text-gray-400"></i>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-xs font-bold text-brand-600 dark:text-brand-400">2</div>
                <span class="text-xs text-gray-600 dark:text-gray-400">Gather documents</span>
                <i data-lucide="arrow-right" class="w-3 h-3 text-gray-400"></i>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-xs font-bold text-brand-600 dark:text-brand-400">3</div>
                <span class="text-xs text-gray-600 dark:text-gray-400">Submit application</span>
                <i data-lucide="arrow-right" class="w-3 h-3 text-gray-400"></i>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-brand-100 dark:bg-brand-900/30 flex items-center justify-center text-xs font-bold text-brand-600 dark:text-brand-400">4</div>
                <span class="text-xs text-gray-600 dark:text-gray-400">Processing ({{ visa.processingTime }})</span>
                <i data-lucide="arrow-right" class="w-3 h-3 text-gray-400"></i>
              </div>
              <div class="flex items-center gap-2">
                <div class="w-8 h-8 rounded-full bg-green-100 dark:bg-green-900/30 flex items-center justify-center text-xs font-bold text-green-600 dark:text-green-400">5</div>
                <span class="text-xs text-gray-600 dark:text-gray-400">Receive visa & relocate</span>
              </div>
            </div>
          </div>
        </div>
      </div>
      {% endfor %}
    </div>

    {# Comparison modal #}
    <div id="vt-compare-modal" class="hidden fixed inset-0 z-50 flex items-center justify-center p-4 bg-black/50 backdrop-blur-sm">
      <div class="bg-white dark:bg-gray-900 rounded-2xl shadow-2xl max-w-5xl w-full max-h-[85vh] overflow-y-auto p-6">
        <div class="flex items-center justify-between mb-6">
          <h2 class="text-xl font-extrabold text-gray-900 dark:text-white">Visa Comparison</h2>
          <button onclick="vtCloseCompare()" class="p-2 rounded-lg hover:bg-gray-100 dark:hover:bg-gray-800">
            <i data-lucide="x" class="w-5 h-5 text-gray-500"></i>
          </button>
        </div>
        <div id="vt-compare-body"></div>
      </div>
    </div>
  </div>
</section>

{# FAQ Section #}
