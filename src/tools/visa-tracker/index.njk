<script>
(function() {
  const visaData = {{ visaTypes | dump | safe }};

  function parseWeeks(timeStr) {
    const s = timeStr.toLowerCase();
    const nums = s.match(/[\d.]+/g);
    if (!nums) return 8;
    if (s.includes('month')) return parseFloat(nums[nums.length - 1]) * 4.3;
    if (s.includes('day')) return parseFloat(nums[nums.length - 1]) / 7;
    return parseFloat(nums[nums.length - 1]);
  }

  function parseMinWeeks(timeStr) {
    const s = timeStr.toLowerCase();
    const nums = s.match(/[\d.]+/g);
    if (!nums) return 4;
    if (s.includes('month')) return parseFloat(nums[0]) * 4.3;
    if (s.includes('day')) return parseFloat(nums[0]) / 7;
    return parseFloat(nums[0]);
  }

  const maxWeeks = 26;

  function initBars() {
    document.querySelectorAll('.vt-bar').forEach(bar => {
      const time = bar.dataset.time;
      const minW = parseMinWeeks(time);
      const maxW = parseWeeks(time);
      const pct = Math.min((maxW / maxWeeks) * 100, 100);
      bar.style.width = pct + '%';

      if (maxW <= 3) bar.className = 'vt-bar h-3 rounded-full transition-all bg-green-500';
      else if (maxW <= 8) bar.className = 'vt-bar h-3 rounded-full transition-all bg-blue-500';
      else bar.className = 'vt-bar h-3 rounded-full transition-all bg-amber-500';
    });

    document.querySelectorAll('.vt-speed-badge').forEach(badge => {
      const time = badge.dataset.speed;
      const w = parseWeeks(time);
      if (w <= 3) { badge.textContent = 'Fast'; badge.classList.add('bg-green-100', 'dark:bg-green-900/30', 'text-green-700', 'dark:text-green-400'); }
      else if (w <= 8) { badge.textContent = 'Average'; badge.classList.add('bg-blue-100', 'dark:bg-blue-900/30', 'text-blue-700', 'dark:text-blue-400'); }
      else { badge.textContent = 'Slow'; badge.classList.add('bg-amber-100', 'dark:bg-amber-900/30', 'text-amber-700', 'dark:text-amber-400'); }
    });
  }

  window.vtToggle = function(slug) {
    const details = document.getElementById('vt-details-' + slug);
    const chevron = document.getElementById('vt-chevron-' + slug);
    details.classList.toggle('hidden');
    chevron.classList.toggle('rotate-180');
  };

  const selected = new Set();

  window.vtUpdateCompare = function() {
    selected.clear();
    document.querySelectorAll('.vt-compare-check:checked').forEach(cb => selected.add(cb.dataset.slug));
    document.getElementById('vt-compare-count').textContent = selected.size;
    const btn = document.getElementById('vt-compare-btn');
    btn.disabled = selected.size < 2;
  };

  window.vtToggleCompare = function() {
    if (selected.size < 2) return;
    const selectedVisas = visaData.filter(v => selected.has(v.slug));
    renderCompare(selectedVisas);
    document.getElementById('vt-compare-modal').classList.remove('hidden');
    document.body.style.overflow = 'hidden';
    if (window.lucide) lucide.createIcons();
  };

  window.vtCloseCompare = function() {
    document.getElementById('vt-compare-modal').classList.add('hidden');
    document.body.style.overflow = '';
  };

  document.getElementById('vt-compare-modal').addEventListener('click', function(e) {
    if (e.target === this) vtCloseCompare();
  });

  function renderCompare(visas) {
    const fields = [
      { key: 'country', label: 'Country' },
      { key: 'category', label: 'Category' },
      { key: 'processingTime', label: 'Processing Time' },
      { key: 'validity', label: 'Validity' },
      { key: 'salaryThreshold', label: 'Salary Threshold' },
      { key: 'spouseWork', label: 'Spouse Work Rights' },
      { key: 'pathToPR', label: 'Path to PR' },
      { key: 'lottery', label: 'Lottery Required', transform: v => v ? 'Yes' : 'No' }
    ];

    let html = '<div class="overflow-x-auto"><table class="w-full text-sm"><thead><tr><th class="text-left p-3 text-gray-500 dark:text-gray-400 font-medium">Feature</th>';
    visas.forEach(v => html += `<th class="text-left p-3 font-bold text-gray-900 dark:text-white">${v.name}</th>`);
    html += '</tr></thead><tbody>';

    fields.forEach((f, i) => {
      const bg = i % 2 === 0 ? 'bg-gray-50 dark:bg-gray-800/50' : '';
      html += `<tr class="${bg}"><td class="p-3 font-medium text-gray-700 dark:text-gray-300">${f.label}</td>`;
      visas.forEach(v => {
        let val = v[f.key];
        if (f.transform) val = f.transform(val);
        html += `<td class="p-3 text-gray-600 dark:text-gray-400">${val}</td>`;
      });
      html += '</tr>';
    });

    html += '<tr class="bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-medium text-gray-700 dark:text-gray-300">Pros</td>';
    visas.forEach(v => {
      html += '<td class="p-3"><ul class="space-y-1">';
      v.pros.forEach(p => html += `<li class="flex items-start gap-1 text-xs text-gray-600 dark:text-gray-400"><i data-lucide="plus-circle" class="w-3 h-3 text-green-500 shrink-0 mt-0.5"></i>${p}</li>`);
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '<tr><td class="p-3 font-medium text-gray-700 dark:text-gray-300">Cons</td>';
    visas.forEach(v => {
      html += '<td class="p-3"><ul class="space-y-1">';
      v.cons.forEach(c => html += `<li class="flex items-start gap-1 text-xs text-gray-600 dark:text-gray-400"><i data-lucide="minus-circle" class="w-3 h-3 text-red-500 shrink-0 mt-0.5"></i>${c}</li>`);
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '<tr class="bg-gray-50 dark:bg-gray-800/50"><td class="p-3 font-medium text-gray-700 dark:text-gray-300">Official Page</td>';
    visas.forEach(v => {
      html += `<td class="p-3"><a href="${v.officialUrl}" target="_blank" rel="noopener" class="text-brand-600 dark:text-brand-400 hover:underline text-xs">Visit &rarr;</a></td>`;
    });
    html += '</tr></tbody></table></div>';

    document.getElementById('vt-compare-body').innerHTML = html;
  }

  document.getElementById('vt-filter').addEventListener('change', applyFilters);
  document.getElementById('vt-sort').addEventListener('change', applyFilters);

  function applyFilters() {
    const country = document.getElementById('vt-filter').value;
    const sort = document.getElementById('vt-sort').value;
    const list = document.getElementById('vt-list');
    const cards = Array.from(list.querySelectorAll('.vt-card'));

    cards.forEach(card => {
      if (!country || card.dataset.country === country) card.classList.remove('hidden');
      else card.classList.add('hidden');
    });

    cards.sort((a, b) => {
      if (sort === 'name') return a.querySelector('h3').textContent.localeCompare(b.querySelector('h3').textContent);
      const aW = parseWeeks(a.dataset.processing);
      const bW = parseWeeks(b.dataset.processing);
      return sort === 'fastest' ? aW - bW : bW - aW;
    });

    cards.forEach(card => list.appendChild(card));
  }

  initBars();
  applyFilters();
})();
</script>
