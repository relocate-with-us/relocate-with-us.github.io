<section class="py-16 bg-gray-50 dark:bg-gray-900/50">
  <div class="max-w-3xl mx-auto px-4">
    <h2 class="section-heading text-center mb-8">Frequently Asked Questions</h2>
    <div class="space-y-4" id="faq-list">
      <div class="card overflow-hidden faq-item">
        <button class="faq-toggle w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
          <span class="font-semibold text-gray-900 dark:text-white pr-4">How much does it cost to relocate abroad for a tech job?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-gray-400 shrink-0 faq-icon transition-transform duration-200"></i>
        </button>
        <div class="faq-content hidden px-6 pb-6">
          <p class="text-gray-600 dark:text-gray-400">The total cost typically ranges from €5,000 to €25,000 depending on the destination city, family size, and shipping needs. Major cost factors include flights (€400–€1,200), first month rent plus deposit (2-3 months rent), visa fees (€100–€2,500), health insurance, and initial living expenses. Cities like Tallinn and Krakow are on the lower end, while London, Zurich, and Sydney are significantly more expensive.</p>
        </div>
      </div>
      <div class="card overflow-hidden faq-item">
        <button class="faq-toggle w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
          <span class="font-semibold text-gray-900 dark:text-white pr-4">What should my employer cover in a relocation package?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-gray-400 shrink-0 faq-icon transition-transform duration-200"></i>
        </button>
        <div class="faq-content hidden px-6 pb-6">
          <p class="text-gray-600 dark:text-gray-400">A good relocation package typically covers visa sponsorship fees, flights for you and your family, temporary housing (1-3 months), a moving or shipping allowance, and sometimes a lump-sum relocation bonus. Companies like Zalando, Booking.com, Mollie, and Spotify offer comprehensive packages. Always negotiate — many companies are flexible even if the initial offer seems fixed.</p>
        </div>
      </div>
      <div class="card overflow-hidden faq-item">
        <button class="faq-toggle w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
          <span class="font-semibold text-gray-900 dark:text-white pr-4">How can I reduce the cost of relocating abroad?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-gray-400 shrink-0 faq-icon transition-transform duration-200"></i>
        </button>
        <div class="faq-content hidden px-6 pb-6">
          <p class="text-gray-600 dark:text-gray-400">Negotiate a better relocation package, ship only essentials (sell furniture and buy locally), stay in temporary furnished housing before committing to a lease, and take advantage of tax benefits like the Netherlands 30% ruling or Germany's relocation expense deductions. Using services like Wise for money transfers also saves on international fees.</p>
        </div>
      </div>
      <div class="card overflow-hidden faq-item">
        <button class="faq-toggle w-full flex items-center justify-between p-6 text-left" aria-expanded="false">
          <span class="font-semibold text-gray-900 dark:text-white pr-4">How much emergency fund should I have when relocating?</span>
          <i data-lucide="chevron-down" class="w-5 h-5 text-gray-400 shrink-0 faq-icon transition-transform duration-200"></i>
        </button>
        <div class="faq-content hidden px-6 pb-6">
          <p class="text-gray-600 dark:text-gray-400">Financial advisors recommend having at least 2-3 months of living expenses saved. This covers unexpected costs, delays in your first salary payment, security deposits, and provides a safety net while you settle into your new city. The exact amount depends on your destination — budget €3,000–€5,000 for affordable cities and €8,000–€15,000 for expensive ones.</p>
        </div>
      </div>
    </div>
  </div>
</section>

{% block scripts %}
<script>
(function() {
  var cities = {{ costOfLiving.cities | jsonify | safe }};
  var visaTypes = {{ visaTypes | jsonify | safe }};

  var flightCosts = {
    'europe': { base: 200, label: 'Within Europe' },
    'asia': { base: 600, label: 'Asia' },
    'north-america': { base: 800, label: 'North America' },
    'south-america': { base: 900, label: 'South America' },
    'africa': { base: 700, label: 'Africa' },
    'middle-east': { base: 500, label: 'Middle East' },
    'oceania': { base: 1100, label: 'Oceania' }
  };

  var visaFeesByCountry = {
    'Germany': { fee: 150, name: 'EU Blue Card' },
    'United Kingdom': { fee: 1500, name: 'Skilled Worker Visa' },
    'Netherlands': { fee: 350, name: 'HSM Visa' },
    'United States': { fee: 2500, name: 'H-1B Visa' },
    'Canada': { fee: 450, name: 'Global Talent Stream' },
    'Australia': { fee: 1400, name: 'TSS Visa 482' },
    'Ireland': { fee: 1000, name: 'Critical Skills Permit' },
    'Sweden': { fee: 250, name: 'Work Permit' },
    'France': { fee: 300, name: 'Passeport Talent' },
    'Switzerland': { fee: 200, name: 'Work Permit' },
    'Estonia': { fee: 160, name: 'Residence Permit' },
    'Portugal': { fee: 200, name: 'Work Visa' },
    'Poland': { fee: 150, name: 'Work Permit' }
  };

  var shippingCosts = { minimal: 200, medium: 1500, full: 5000 };
  var healthInsurancePerMonth = 250;
  var currentStep = 1;

  function showStep(n) {
    for (var i = 1; i <= 4; i++) {
      var panel = document.getElementById('step-' + i);
      var dot = document.querySelector('.step-dot[data-step="' + i + '"]');
      if (i === n) {
        panel.classList.remove('hidden');
        dot.classList.add('bg-brand-600', 'text-white');
        dot.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-500');
      } else {
        panel.classList.add('hidden');
        if (i < n) {
          dot.classList.add('bg-brand-600', 'text-white');
          dot.classList.remove('bg-gray-200', 'dark:bg-gray-700', 'text-gray-500');
        } else {
          dot.classList.remove('bg-brand-600', 'text-white');
          dot.classList.add('bg-gray-200', 'dark:bg-gray-700', 'text-gray-500');
        }
      }
    }
    currentStep = n;
    if (window.lucide) lucide.createIcons();
  }

  document.querySelectorAll('.step-next').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var next = parseInt(this.getAttribute('data-next'));
      showStep(next);
    });
  });

  document.querySelectorAll('.step-prev').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var prev = parseInt(this.getAttribute('data-prev'));
      showStep(prev);
    });
  });

  var destSelect = document.getElementById('destination');
  var originSelect = document.getElementById('origin');
  var step1Next = document.querySelector('#step-1 .step-next');
  var step2Next = document.querySelector('#step-2 .step-next');

  destSelect.addEventListener('change', function() {
    step1Next.disabled = !this.value;
  });
  originSelect.addEventListener('change', function() {
    step2Next.disabled = !this.value;
  });

  var familySelect = document.getElementById('family');
  var kidsInput = document.getElementById('kids-input');
  familySelect.addEventListener('change', function() {
    kidsInput.classList.toggle('hidden', this.value !== 'family');
  });

  document.querySelectorAll('.shipping-option').forEach(function(label) {
    label.addEventListener('click', function() {
      document.querySelectorAll('.shipping-option').forEach(function(l) {
        l.classList.remove('border-brand-500', 'dark:border-brand-500', 'bg-brand-50', 'dark:bg-brand-900/10');
      });
      this.classList.add('border-brand-500', 'dark:border-brand-500', 'bg-brand-50', 'dark:bg-brand-900/10');
    });
  });

  function fmt(n) {
    return '€' + Math.round(n).toLocaleString('en-US');
  }

  function getCityData(slug) {
    for (var i = 0; i < cities.length; i++) {
      if (cities[i].slug === slug) return cities[i];
    }
    return null;
  }

  function makeLine(icon, label, amount, note) {
    return '<div class="flex items-center justify-between py-3 border-b border-gray-100 dark:border-gray-800">' +
      '<div class="flex items-center gap-3">' +
      '<i data-lucide="' + icon + '" class="w-5 h-5 text-gray-400"></i>' +
      '<div><p class="font-medium text-gray-900 dark:text-white">' + label + '</p>' +
      (note ? '<p class="text-xs text-gray-500 dark:text-gray-400">' + note + '</p>' : '') +
      '</div></div>' +
      '<span class="font-semibold text-gray-900 dark:text-white">' + fmt(amount) + '</span></div>';
  }

  document.getElementById('calculate-btn').addEventListener('click', function() {
    var city = getCityData(destSelect.value);
    if (!city) return;
    var origin = originSelect.value;
    var familyType = familySelect.value;
    var kidsCount = parseInt(document.getElementById('kids-count').value) || 1;
    var shipping = document.querySelector('input[name="shipping"]:checked').value;

    var people = familyType === 'single' ? 1 : familyType === 'couple' ? 2 : 2 + kidsCount;

    var flightPerPerson = flightCosts[origin] ? flightCosts[origin].base : 600;
    var flights = flightPerPerson * people;

    var visaInfo = visaFeesByCountry[city.country] || { fee: 300, name: 'Work Visa' };
    var visaFee = visaInfo.fee * (familyType === 'single' ? 1 : people);

    var rent = familyType === 'single' ? city.rent1bed : city.rent3bed;
    var depositMonths = 2.5;
    var housing = rent + (rent * depositMonths);

    var insurance = healthInsurancePerMonth * people * 3;

    var monthlyLiving = city.groceries + city.transport + city.utilities + city.internet;
    var livingExpenses = monthlyLiving * (familyType === 'single' ? 1 : (people * 0.7));

    var shippingCost = shippingCosts[shipping] * (familyType === 'single' ? 1 : 1.5);

    var emergencyFund = (rent + monthlyLiving) * 2;

    var total = flights + visaFee + housing + insurance + livingExpenses + shippingCost + emergencyFund;

    var html = '';
    html += makeLine('plane', 'Flights (' + people + ' ' + (people === 1 ? 'person' : 'people') + ')', flights, 'From ' + (flightCosts[origin] ? flightCosts[origin].label : origin) + ' to ' + city.name);
    html += makeLine('stamp', 'Visa Fees — ' + visaInfo.name, visaFee, city.country + (people > 1 ? ' (including dependents)' : ''));
    html += makeLine('home', 'First Month Rent + Deposit', housing, fmt(rent) + '/month rent + ' + depositMonths + ' months deposit in ' + city.name);
    html += makeLine('heart-pulse', 'Health Insurance (3 months)', insurance, fmt(healthInsurancePerMonth) + '/person/month for ' + people + ' ' + (people === 1 ? 'person' : 'people'));
    html += makeLine('shopping-cart', 'First Month Living Expenses', livingExpenses, 'Groceries, transport, utilities, internet');
    html += makeLine('package', 'Shipping (' + shipping + ')', shippingCost, shipping === 'minimal' ? 'Extra luggage fees' : shipping === 'medium' ? 'Courier boxes' : 'International movers');
    html += makeLine('shield', 'Emergency Fund (2 months)', emergencyFund, 'Recommended safety net');

    document.getElementById('cost-breakdown').innerHTML = html;
    document.getElementById('cost-total').innerHTML =
      '<div class="flex items-center justify-between">' +
      '<div><p class="text-xl font-bold text-gray-900 dark:text-white">Total Estimated Cost</p>' +
      '<p class="text-sm text-gray-500 dark:text-gray-400">For relocating to ' + city.name + ', ' + city.country + '</p></div>' +
      '<span class="text-3xl font-extrabold text-brand-600 dark:text-brand-400">' + fmt(total) + '</span></div>';

    document.getElementById('result-summary-text').textContent =
      'Moving to ' + city.name + ' as a ' + (familyType === 'family' ? 'family of ' + people : familyType) +
      ' from ' + (flightCosts[origin] ? flightCosts[origin].label : origin) +
      ' with ' + shipping + ' shipping — here is your estimated cost breakdown.';

    document.getElementById('calculator-form').classList.add('hidden');
    document.getElementById('results').classList.remove('hidden');
    window.scrollTo({ top: document.getElementById('results').offsetTop - 100, behavior: 'smooth' });
    if (window.lucide) lucide.createIcons();
  });

  document.getElementById('recalculate-btn').addEventListener('click', function() {
    document.getElementById('results').classList.add('hidden');
    document.getElementById('calculator-form').classList.remove('hidden');
    showStep(1);
    window.scrollTo({ top: document.getElementById('calculator-form').offsetTop - 100, behavior: 'smooth' });
  });

  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
{% endblock %}
