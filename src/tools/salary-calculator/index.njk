<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Salary After Tax Calculator for Expats",
  "url": "{{ site.url }}/tools/salary-calculator/",
  "description": "{{ description }}",
  "applicationCategory": "FinanceApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "publisher": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Which European country has the lowest taxes for tech workers?",
      "acceptedAnswer": { "@type": "Answer", "text": "Estonia has one of the lowest tax burdens in the EU with a flat 20% income tax rate. Switzerland also offers competitive rates depending on the canton. The Netherlands 30% ruling can significantly reduce the effective tax rate for qualifying expats." }
    },
    {
      "@type": "Question",
      "name": "What is the Netherlands 30% ruling?",
      "acceptedAnswer": { "@type": "Answer", "text": "The 30% ruling allows qualifying expats recruited from abroad to receive 30% of their gross salary tax-free for up to 5 years. You must have specific expertise and meet a minimum salary threshold of €46,107 (or €35,048 if under 30 with an MSc)." }
    },
    {
      "@type": "Question",
      "name": "How does the EU Blue Card affect my taxes?",
      "acceptedAnswer": { "@type": "Answer", "text": "The EU Blue Card itself does not provide tax benefits — you pay the standard tax rates of the country you work in. However, some countries like Germany, Netherlands, and France offer separate tax incentives for highly skilled foreign workers." }
    },
    {
      "@type": "Question",
      "name": "Do I pay social security as an expat?",
      "acceptedAnswer": { "@type": "Answer", "text": "In most countries, yes. Social security contributions are mandatory for employed workers. Rates vary significantly: France charges ~22% employee share, while Australia and Estonia have minimal employee contributions. Some bilateral agreements prevent double contributions." }
    },
    {
      "@type": "Question",
      "name": "Is this calculator accurate?",
      "acceptedAnswer": { "@type": "Answer", "text": "This calculator provides estimates based on standard tax brackets and rates for 2025/2026. Actual take-home pay may vary based on personal circumstances, deductions, credits, marital status, and local taxes (especially in Switzerland, Canada, and Sweden). Always consult a local tax advisor for precise calculations." }
    }
  ]
}
</script>
