{% block scripts %}
<script>
(function() {
  var salaryData = {{ salaryData | jsonify | safe }};
  var countriesMap = {};
  salaryData.countries.forEach(function(c) { countriesMap[c.slug] = c; });

  function calculateTax(gross, brackets) {
    var tax = 0;
    for (var i = 0; i < brackets.length; i++) {
      var b = brackets[i];
      var max = b.max || Infinity;
      if (gross > b.min) {
        var taxable = Math.min(gross, max) - b.min;
        tax += taxable * (b.rate / 100);
      }
    }
    return tax;
  }

  function calculateSocial(gross, country) {
    if (!country.socialSecurity) return 0;
    var base = gross;
    if (country.socialSecurityCap) {
      base = Math.min(gross, country.socialSecurityCap);
    }
    if (country.slug === 'uk') {
      var social = 0;
      var min = country.socialSecurityMin || 0;
      var max = country.socialSecurityMax || Infinity;
      if (gross > min) {
        social += (Math.min(gross, max) - min) * (country.socialSecurity / 100);
      }
      if (gross > max && country.socialSecurityAbove) {
        social += (gross - max) * (country.socialSecurityAbove / 100);
      }
      return social;
    }
    return base * (country.socialSecurity / 100);
  }

  function calculateUSC(gross, uscBrackets) {
    if (!uscBrackets) return 0;
    var usc = 0;
    for (var i = 0; i < uscBrackets.length; i++) {
      var b = uscBrackets[i];
      var max = b.max || Infinity;
      if (gross > b.min) {
        var taxable = Math.min(gross, max) - b.min;
        usc += taxable * (b.rate / 100);
      }
    }
    return usc;
  }

  function fullCalc(gross, countrySlug) {
    var c = countriesMap[countrySlug];
    if (!c) return null;
    var incomeTax = calculateTax(gross, c.brackets);
    var socialSec = calculateSocial(gross, c);
    var usc = calculateUSC(gross, c.usc);
    var totalDeductions = incomeTax + socialSec + usc;
    var net = gross - totalDeductions;
    return {
      country: c,
      gross: gross,
      incomeTax: incomeTax,
      socialSecurity: socialSec + usc,
      net: Math.max(0, net),
      effectiveRate: gross > 0 ? ((totalDeductions / gross) * 100) : 0
    };
  }

  function fmt(val, symbol) {
    return symbol + Math.round(val).toLocaleString();
  }

  // Single calculation
  var calcBtn = document.getElementById('calculate-btn');
  calcBtn.addEventListener('click', function() {
    var gross = parseFloat(document.getElementById('salary-input').value);
    var slug = document.getElementById('country-select').value;
    if (!gross || !slug) return;

    var result = fullCalc(gross, slug);
    if (!result) return;
    var c = result.country;
    var s = c.currencySymbol;

    document.getElementById('res-gross').textContent = fmt(result.gross, s);
    document.getElementById('res-tax').textContent = '-' + fmt(result.incomeTax, s);
    document.getElementById('res-social').textContent = '-' + fmt(result.socialSecurity, s);
    document.getElementById('res-net').textContent = fmt(result.net, s);
    document.getElementById('res-effective').textContent = result.effectiveRate.toFixed(1) + '%';
    document.getElementById('res-monthly-val').textContent = fmt(result.net / 12, s) + '/month';

    var netPct = (result.net / result.gross * 100).toFixed(1);
    var taxPct = (result.incomeTax / result.gross * 100).toFixed(1);
    var socPct = (result.socialSecurity / result.gross * 100).toFixed(1);
    document.getElementById('bar-net').style.width = netPct + '%';
    document.getElementById('bar-tax').style.width = taxPct + '%';
    document.getElementById('bar-social').style.width = socPct + '%';

    document.getElementById('res-country-name').textContent = c.name;
    document.getElementById('avg-junior').textContent = fmt(c.avgTechSalary.junior, s);
    document.getElementById('avg-mid').textContent = fmt(c.avgTechSalary.mid, s);
    document.getElementById('avg-senior').textContent = fmt(c.avgTechSalary.senior, s);
    document.getElementById('res-notes').textContent = c.notes || '';

    var specialDiv = document.getElementById('res-special-rules');
    if (c.specialRules && c.specialRules.length > 0) {
      var html = '';
      c.specialRules.forEach(function(rule) {
        html += '<div class="p-4 bg-yellow-50 dark:bg-yellow-900/20 rounded-xl border border-yellow-200 dark:border-yellow-800 mb-3">' +
          '<p class="font-semibold text-yellow-800 dark:text-yellow-300 mb-1 flex items-center gap-2"><i data-lucide="sparkles" class="w-4 h-4"></i>' + rule.name + '</p>' +
          '<p class="text-sm text-yellow-700 dark:text-yellow-400">' + rule.description + '</p>' +
          '<p class="text-xs text-yellow-600 dark:text-yellow-500 mt-1">Eligibility: ' + rule.eligible + '</p></div>';
      });
      specialDiv.innerHTML = html;
      specialDiv.classList.remove('hidden');
    } else {
      specialDiv.classList.add('hidden');
    }

    var guideDiv = document.getElementById('res-guide-link');
    if (c.guideUrl) {
      document.getElementById('guide-link-anchor').href = c.guideUrl;
      guideDiv.classList.remove('hidden');
    } else {
      guideDiv.classList.add('hidden');
    }

    document.getElementById('single-result').classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
  });

  // Comparison
  var compareBtn = document.getElementById('compare-btn');
  compareBtn.addEventListener('click', function() {
    var gross = parseFloat(document.getElementById('compare-salary').value);
    var slugs = [
      document.getElementById('compare-c1').value,
      document.getElementById('compare-c2').value,
      document.getElementById('compare-c3').value
    ].filter(Boolean);

    if (!gross || slugs.length < 2) return;

    var results = slugs.map(function(slug) { return fullCalc(gross, slug); }).filter(Boolean);
    if (results.length < 2) return;

    var maxNet = Math.max.apply(null, results.map(function(r) { return r.net; }));

    var cardsHtml = results.map(function(r) {
      var s = r.country.currencySymbol;
      var isBest = r.net === maxNet;
      return '<div class="card p-6 compare-col' + (isBest ? ' ring-2 ring-green-500' : '') + '">' +
        (isBest ? '<span class="badge badge-visa mb-3">Best Net Pay</span>' : '') +
        '<h3 class="text-lg font-semibold text-gray-900 dark:text-white mb-4">' + r.country.name + '</h3>' +
        '<div class="space-y-3">' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Gross</span><span class="font-medium text-gray-900 dark:text-white">' + fmt(r.gross, s) + '</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Income Tax</span><span class="font-medium text-red-600 dark:text-red-400">-' + fmt(r.incomeTax, s) + '</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Social Security</span><span class="font-medium text-orange-600 dark:text-orange-400">-' + fmt(r.socialSecurity, s) + '</span></div>' +
          '<div class="border-t border-gray-200 dark:border-gray-700 pt-3 flex justify-between"><span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Net Salary</span><span class="text-xl font-bold text-green-600 dark:text-green-400">' + fmt(r.net, s) + '</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Effective Rate</span><span class="font-medium text-gray-900 dark:text-white">' + r.effectiveRate.toFixed(1) + '%</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Monthly Net</span><span class="font-medium text-gray-900 dark:text-white">' + fmt(r.net / 12, s) + '</span></div>' +
        '</div>' +
      '</div>';
    }).join('');
    document.getElementById('compare-cards').innerHTML = cardsHtml;

    var barsMaxNet = Math.max.apply(null, results.map(function(r) { return r.net; }));
    var barsHtml = results.map(function(r) {
      var pct = barsMaxNet > 0 ? (r.net / barsMaxNet * 100) : 0;
      return '<div class="flex items-center gap-4">' +
        '<span class="text-sm font-medium text-gray-700 dark:text-gray-300 w-28 shrink-0">' + r.country.name + '</span>' +
        '<div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-6 overflow-hidden">' +
          '<div class="tax-bar bg-green-500 h-full rounded-full flex items-center justify-end pr-2" style="width:' + pct + '%">' +
            '<span class="text-xs font-medium text-white">' + fmt(r.net, r.country.currencySymbol) + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
    document.getElementById('compare-bars').innerHTML = barsHtml;

    document.getElementById('compare-results').classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
  });

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
{% endblock %}
