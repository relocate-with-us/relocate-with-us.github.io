      ]
    }
  };

  var commonPhase1 = [
    'Accept job offer and sign employment contract',
    'Begin visa/work permit application',
    'Arrange health insurance for transition period',
    'Book flights to destination',
    'Arrange temporary accommodation (2–4 weeks)',
    'Notify current employer and serve notice period',
    'Get important documents: apostilled degree, birth certificate, passport photos',
    'Open international bank account (Wise, Revolut)',
    'Research housing market in destination city',
    'Start language learning (if applicable)'
  ];

  var countrySelect = document.getElementById('country-select');
  var timelineSelect = document.getElementById('timeline-select');
  var generateBtn = document.getElementById('generate-btn');
  var container = document.getElementById('checklist-container');
  var phasesContainer = document.getElementById('phases-container');
  var progressBar = document.getElementById('progress-bar');
  var progressText = document.getElementById('progress-text');
  var printBtn = document.getElementById('print-btn');
  var resetBtn = document.getElementById('reset-btn');
  var copyLinkBtn = document.getElementById('copy-link-btn');

  function getStorageData() {
    try { return JSON.parse(localStorage.getItem(STORAGE_KEY)) || {}; } catch(e) { return {}; }
  }

  function saveStorageData(data) {
    try { localStorage.setItem(STORAGE_KEY, JSON.stringify(data)); } catch(e) {}
  }

  function updateProgress() {
    var boxes = phasesContainer.querySelectorAll('input[type="checkbox"]');
    if (!boxes.length) return;
    var checked = 0;
    boxes.forEach(function(cb) { if (cb.checked) checked++; });
    var pct = Math.round((checked / boxes.length) * 100);
    progressBar.style.width = pct + '%';
    progressText.textContent = pct + '%';
  }

  function generateChecklist() {
    var country = countrySelect.value;
    var timeline = timelineSelect.value;
    if (!country) {
      countrySelect.focus();
      countrySelect.classList.add('ring-2', 'ring-red-500');
      setTimeout(function() { countrySelect.classList.remove('ring-2', 'ring-red-500'); }, 2000);
      return;
    }

    var data = countryData[country];
    var stored = getStorageData();
    var key = country + '-' + timeline;

    document.getElementById('checklist-title').textContent = data.emoji + ' ' + data.name + ' Relocation Checklist';
    document.getElementById('checklist-subtitle').textContent = timeline + '-month timeline • ' + (new Date().toLocaleDateString('en-US', { month: 'long', year: 'numeric' }));

    var phases = [
      {
        icon: 'calendar',
        title: 'Phase 1 — Before You Leave',
        subtitle: timeline === '1' ? '30 days before' : (timeline === '2' ? '60–30 days before' : '90–30 days before'),
        color: 'blue',
        items: commonPhase1.concat(data.phase1Extra)
      },
      {
        icon: 'plane-landing',
        title: 'Phase 2 — First Week',
        subtitle: 'Days 1–7 after arrival',
        color: 'green',
        items: data.phase2
      },
      {
        icon: 'home',
        title: 'Phase 3 — First Month',
        subtitle: 'Weeks 2–4',
        color: 'purple',
        items: data.phase3
      },
      {
        icon: 'trophy',
        title: 'Phase 4 — First 3 Months',
        subtitle: 'Months 1–3',
        color: 'amber',
        items: data.phase4Extra
      }
    ];

    var colorMap = {
      blue: 'bg-blue-100 dark:bg-blue-900/30 text-blue-600 dark:text-blue-400',
      green: 'bg-green-100 dark:bg-green-900/30 text-green-600 dark:text-green-400',
      purple: 'bg-purple-100 dark:bg-purple-900/30 text-purple-600 dark:text-purple-400',
      amber: 'bg-amber-100 dark:bg-amber-900/30 text-amber-600 dark:text-amber-400'
    };

    var html = '';
    var itemIdx = 0;
    phases.forEach(function(phase) {
      html += '<div class="border border-gray-200 dark:border-gray-700 rounded-xl overflow-hidden">';
      html += '<div class="bg-gray-50 dark:bg-gray-800/50 px-5 py-4 flex items-center gap-3">';
      html += '<div class="w-10 h-10 rounded-lg flex items-center justify-center ' + colorMap[phase.color] + '">';
      html += '<i data-lucide="' + phase.icon + '" class="w-5 h-5"></i></div>';
      html += '<div><h3 class="font-semibold text-gray-900 dark:text-white">' + phase.title + '</h3>';
      html += '<p class="text-xs text-gray-500 dark:text-gray-400">' + phase.subtitle + '</p></div></div>';
      html += '<div class="divide-y divide-gray-100 dark:divide-gray-800">';

      phase.items.forEach(function(item) {
        var id = 'item-' + itemIdx;
        var checked = stored[key] && stored[key][id];
        html += '<label for="' + id + '" class="flex items-start gap-3 px-5 py-3 cursor-pointer hover:bg-gray-50 dark:hover:bg-gray-800/30 transition-colors">';
        html += '<input type="checkbox" id="' + id + '" class="mt-1 h-4 w-4 rounded border-gray-300 text-brand-600 focus:ring-brand-500"' + (checked ? ' checked' : '') + '>';
        html += '<span class="text-sm text-gray-700 dark:text-gray-300' + (checked ? ' line-through opacity-60' : '') + '">' + item + '</span>';
        html += '</label>';
        itemIdx++;
      });

      html += '</div></div>';
    });

    if (data.guideUrl) {
      html += '<div class="bg-green-50 dark:bg-green-900/20 border-l-4 border-green-400 p-4 rounded-r-lg mt-6">';
      html += '<div class="flex gap-3"><i data-lucide="book-open" class="w-5 h-5 text-green-500 shrink-0 mt-0.5"></i>';
      html += '<div><p class="text-sm font-medium text-green-800 dark:text-green-300">Read our full ' + data.name + ' guide</p>';
      html += '<a href="' + data.guideUrl + '" class="text-sm text-green-600 dark:text-green-400 underline hover:no-underline">View the ' + data.name + ' Country Guide →</a></div></div></div>';
    }

    phasesContainer.innerHTML = html;
    container.classList.remove('hidden');
    if (window.lucide) lucide.createIcons();
    updateProgress();

    phasesContainer.querySelectorAll('input[type="checkbox"]').forEach(function(cb) {
      cb.addEventListener('change', function() {
        var st = getStorageData();
        if (!st[key]) st[key] = {};
        st[key][cb.id] = cb.checked;
        saveStorageData(st);
        var span = cb.nextElementSibling;
        if (cb.checked) { span.classList.add('line-through', 'opacity-60'); }
        else { span.classList.remove('line-through', 'opacity-60'); }
        updateProgress();
      });
    });

    container.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  generateBtn.addEventListener('click', generateChecklist);

  printBtn.addEventListener('click', function() { window.print(); });

  resetBtn.addEventListener('click', function() {
    var country = countrySelect.value;
    var timeline = timelineSelect.value;
    if (!country) return;
    var key = country + '-' + timeline;
    var st = getStorageData();
    delete st[key];
    saveStorageData(st);
    generateChecklist();
  });

  copyLinkBtn.addEventListener('click', function() {
    navigator.clipboard.writeText(window.location.href).then(function() {
      copyLinkBtn.innerHTML = '<i data-lucide="check" class="w-4 h-4 mr-1"></i> Copied!';
      if (window.lucide) lucide.createIcons();
      setTimeout(function() {
        copyLinkBtn.innerHTML = '<i data-lucide="link" class="w-4 h-4 mr-1"></i> Copy Link';
        if (window.lucide) lucide.createIcons();
      }, 2000);
    });
  });
});
</script>