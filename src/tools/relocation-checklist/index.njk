      ]
    },
    canada: {
      name: 'Canada', emoji: '🇨🇦', guideUrl: '/resources/country-guides/canada/',
      phase1Extra: [
        'Apply for work permit or permanent residency (Express Entry)',
        'Get ECA (Educational Credential Assessment)',
        'Arrange health coverage for initial period before provincial health kicks in',
        'Get police clearance certificate'
      ],
      phase2: [
        'Apply for SIN (Social Insurance Number) at Service Canada',
        'Open Canadian bank account (RBC, TD, Scotiabank, BMO)',
        'Get Canadian SIM card (Rogers, Bell, Telus)',
        'Register for provincial health insurance (OHIP, MSP, etc.) — may have waiting period',
        'Apply for SIN if not done at airport',
        'Get PRESTO / Compass / Opus card for public transport'
      ],
      phase3: [
        'Find permanent housing (Realtor.ca, Rentals.ca, Kijiji)',
        'Get provincial driver\'s license',
        'Set up utilities (electricity, gas, internet)',
        'Join expat communities (InterNations, Reddit)',
        'Register with your home country embassy/consulate (optional)',
        'Register for GST/HST credit if eligible'
      ],
      phase4Extra: [
        'Complete probation milestones',
        'File CRA tax registration',
        'Get permanent phone plan',
        'Build professional network — Toronto Tech Meetup, etc.',
        'Explore Canada'
      ]
    },
    estonia: {
      name: 'Estonia', emoji: '🇪🇪',
      phase1Extra: [
        'Apply for Estonian work visa or apply for Digital Nomad Visa',
        'Employer registers employment in Estonian register',
        'Arrange health insurance',
        'Research e-Residency if applicable'
      ],
      phase2: [
        'Register residence at local government office (within 30 days)',
        'Open Estonian bank account (LHV, Swedbank, SEB)',
        'Get Estonian SIM card (Telia, Elisa, Tele2)',
        'Get personal identification code (isikukood)',
        'Register for Estonian health insurance (Haigekassa)',
        'Get Tallinn public transport card (free for residents)'
      ],
      phase3: [
        'Find permanent housing (City24, KV.ee)',
        'Collect residence permit from Police and Border Guard Board',
        'Set up utilities (electricity, internet)',
        'Join expat communities (e-Residency community, InterNations Tallinn)',
