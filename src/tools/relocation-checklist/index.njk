{% block structuredData %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "Relocation Checklist Generator",
  "url": "{{ site.url }}{{ page.url }}",
  "description": "{{ description }}",
  "applicationCategory": "LifestyleApplication",
  "operatingSystem": "Any",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "publisher": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "How far in advance should I start planning my relocation?",
      "acceptedAnswer": { "@type": "Answer", "text": "Ideally 2-3 months before your move date. Visa processing alone can take 2-8 weeks depending on the country. Starting early gives you time for document apostille, housing research, and proper notice to your current employer." }
    },
    {
      "@type": "Question",
      "name": "What documents do I need to relocate abroad for work?",
      "acceptedAnswer": { "@type": "Answer", "text": "Common documents include: valid passport, signed employment contract, university degree (often apostilled), birth certificate, health insurance proof, passport photos, and proof of accommodation. Requirements vary by country." }
    },
    {
      "@type": "Question",
      "name": "Do I need to register my address when moving to a new country?",
      "acceptedAnswer": { "@type": "Answer", "text": "Yes, most countries require address registration within days or weeks of arrival. In Germany it's Anmeldung (within 14 days), in the Netherlands you register at the municipality to get your BSN, and in Sweden you register with Skatteverket for your personnummer." }
    },
    {
      "@type": "Question",
      "name": "Should I open a local bank account before or after moving?",
      "acceptedAnswer": { "@type": "Answer", "text": "It's recommended to have an international-friendly account (like Wise or Revolut) before moving, and then open a local bank account within the first week of arrival. You'll typically need your address registration and ID to open a local account." }
    },
    {
      "@type": "Question",
      "name": "What is the Anmeldung in Germany?",
      "acceptedAnswer": { "@type": "Answer", "text": "Anmeldung is the mandatory address registration in Germany. You must register at the local Bürgeramt within 14 days of moving in. You'll need your passport, rental contract, and a landlord confirmation form (Wohnungsgeberbestätigung). This is required for almost everything else—bank accounts, tax ID, insurance." }
    }
  ]
}
</script>
{% endblock %}

