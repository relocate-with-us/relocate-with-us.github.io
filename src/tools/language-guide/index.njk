      government: 'Government offices (SEF/AIMA, Finanças) primarily operate in Portuguese. The bureaucracy can be challenging even for Portuguese speakers. Hiring an accountant or immigration lawyer is strongly recommended. Some services are being digitized with English options.',
      recommendedLevel: 'A2',
      resources: ['IEFP-funded Portuguese courses (free for residents)', 'Practice Portuguese podcast', 'Instituto Camões', 'Language exchanges in Lisbon/Porto'],
      tips: ['Lisbon and Porto are the main tech hubs', 'Portuguese people are incredibly welcoming to those who try to learn', 'The NHR tax regime can be very beneficial for tech workers', 'The startup ecosystem is growing rapidly with many English-speaking roles']
    },
    {
      id: 'poland', name: 'Poland', flag: '🇵🇱', language: 'Polish',
      englishFriendly: false,
      visaLanguage: { requirement: 'None', detail: 'No Polish required for work permits or the EU Blue Card. For permanent residence, basic Polish knowledge is assessed informally. Citizenship requires B1 Polish and passing a civic knowledge test.' },
      workplace: { summary: 'English in tech, Polish elsewhere', detail: 'The tech sector in Warsaw, Krakow, and Wroclaw operates largely in English. International companies and outsourcing firms use English as the default. Polish companies outside tech tend to require Polish.' },
      dailyLife: { rating: 2, detail: 'English proficiency varies significantly. Young people in cities speak good English, but older generations and rural areas have limited English. Shopping and restaurants in city centers work in English, but doctor visits, car services, and government offices often require Polish.' },
      government: 'Government offices operate in Polish. Immigration offices (Urząd Wojewódzki) have limited English support. Official documents and letters are in Polish. An immigration lawyer or translator is recommended for permit applications.',
      recommendedLevel: 'A2',
      resources: ['Polish language schools in major cities', 'PolishPod101', 'Duolingo Polish', 'University-affiliated language courses'],
      tips: ['Krakow and Warsaw have thriving English-speaking tech communities', 'Poland offers excellent value — high tech salaries relative to cost of living', 'Polish is a difficult language to learn but locals are very appreciative of any effort', 'The expat community is growing rapidly, especially in Krakow']
    },
    {
      id: 'denmark', name: 'Denmark', flag: '🇩🇰', language: 'Danish',
      englishFriendly: true,
      visaLanguage: { requirement: 'None for work permit', detail: 'No Danish required for the Positive List work permit or Pay Limit scheme. For permanent residence (after 4 years), you must pass Danish language test level 2 (PD2). Citizenship requires PD3 level.' },
      workplace: { summary: 'English is standard', detail: 'Danes have near-native English fluency. Most tech companies in Copenhagen use English as the working language. Startups, scale-ups, and international companies operate entirely in English. Some traditional Danish companies prefer Danish.' },
      dailyLife: { rating: 4, detail: 'Almost everyone speaks excellent English. You can handle all daily tasks in English. Some government communications arrive in Danish, and the Digital Post (e-Boks) system is primarily in Danish.' },
      government: 'SIRI (immigration agency) provides English services. Borger.dk has some English content. Tax agency (SKAT) has English support. Most official letters are in Danish but can be translated through services provided to expats.',
      recommendedLevel: 'A2',
      resources: ['Sprogskole (municipality language schools — free for certain visa holders)', 'Danish classes at Studieskolen', 'DR Nyheder (news in simple Danish)', 'Duolingo Danish'],
      tips: ['Copenhagen is the main tech hub with companies like Zendesk, Unity, and Maersk', 'Danish pronunciation is notoriously difficult — don\'t get discouraged', 'Free language courses (sprogskole) are available for work permit holders', 'Danes socialize differently — join clubs and sports to make friends']
    },
    {
      id: 'czech-republic', name: 'Czech Republic', flag: '🇨🇿', language: 'Czech',
      englishFriendly: false,
      visaLanguage: { requirement: 'None', detail: 'No Czech required for work permits or the EU Blue Card. For permanent residence after 5 years, you must pass a Czech language exam at A1 level. Citizenship requires B1 level Czech.' },
      workplace: { summary: 'English common in tech', detail: 'Prague\'s tech scene is English-friendly, especially at international companies and startups. Many global companies have offices in Prague (Microsoft, Oracle, JetBrains). Czech companies outside the tech bubble generally require Czech.' },
      dailyLife: { rating: 2, detail: 'English is spoken by younger people in Prague, but less so in other cities and among older generations. Daily tasks like visiting a doctor, dealing with landlords, or navigating public services often require Czech. Restaurant and shop staff in central Prague usually speak some English.' },
      government: 'Government offices operate in Czech. Immigration offices (OAMP) have limited English support. Official documents and administrative processes are in Czech. A Czech-speaking friend or immigration consultant is very helpful.',
      recommendedLevel: 'A2',
      resources: ['Czech language courses at Charles University', 'Local language schools (Akcent, Czech Courses)', 'CzechClass101', 'Tandem language exchange meetups in Prague'],
      tips: ['Prague has the strongest tech job market and most English-friendly environment', 'Brno is an emerging tech hub with lower costs', 'Czech is a Slavic language — easier if you know Polish, Slovak, or Russian', 'The cost of living is very affordable compared to Western Europe']
    },
    {
      id: 'france', name: 'France', flag: '🇫🇷', language: 'French',
      englishFriendly: false,
      visaLanguage: { requirement: 'None for Passeport Talent', detail: 'No French required for the Passeport Talent visa (for skilled workers and tech). For permanent residence (carte de résident), A2 French is required. Citizenship requires B1 French oral and written, plus a civic knowledge test.' },
      workplace: { summary: 'French often expected', detail: 'While Paris\'s startup ecosystem (Station F, La French Tech) has many English-speaking companies, French is still the dominant business language. International companies and English-friendly startups exist, but they\'re a smaller percentage than in the Netherlands or Germany. Lyon and other cities tend to require more French.' },
      dailyLife: { rating: 2, detail: 'Despite its international reputation, France has lower English proficiency than Northern European countries. In Paris, many people speak some English, but outside the capital, French is essential. Daily interactions — shopping, healthcare, services — are much easier with French.' },
      government: 'Government services are conducted in French. Préfecture appointments, social security (CPAM), and tax services operate in French. Online services at service-public.fr are in French. Some international offices in Paris have limited English support.',
      recommendedLevel: 'B1',
      resources: ['Alliance Française (worldwide)', 'OFII-sponsored integration courses', 'TV5Monde (free learning resources)', 'France Langue schools'],
      tips: ['Paris has the largest tech ecosystem in France (Station F, La French Tech)', 'French people appreciate any effort to speak French — even basic phrases go a long way', 'The Passeport Talent visa is very attractive with no language requirement', 'Learn French if you plan to stay long-term — it opens many more opportunities']
    }
  ];

  var selectedCountry = null;
  var compareSet = {};

  function renderStars(rating) {
    var html = '';
    for (var i = 1; i <= 5; i++) {
      html += '<i data-lucide="star" class="w-4 h-4 inline ' + (i <= rating ? 'star-filled fill-amber-400' : 'star-empty') + '"></i>';
    }
    return html;
  }

  function renderSummary() {
    var englishCount = 0;
    var helpfulCount = 0;
    countries.forEach(function(c) {
      if (c.englishFriendly) englishCount++;
      else helpfulCount++;
    });
    document.getElementById('english-count').textContent = englishCount;
    document.getElementById('helpful-count').textContent = helpfulCount;
    document.getElementById('countries-count').textContent = countries.length;
  }

  function renderCountryGrid() {
    var grid = document.getElementById('country-grid');
    var html = '';
    countries.forEach(function(c) {
      html += '<button class="country-btn card p-4 text-center hover:border-violet-300 dark:hover:border-violet-600 transition-all cursor-pointer group" data-country="' + c.id + '">';
      html += '<span class="text-3xl block mb-2">' + c.flag + '</span>';
      html += '<span class="font-semibold text-sm text-gray-900 dark:text-white group-hover:text-violet-600 dark:group-hover:text-violet-400 block">' + c.name + '</span>';
      html += '<span class="text-xs text-gray-500 dark:text-gray-400 block mt-1">' + c.language + '</span>';
      if (c.englishFriendly) {
        html += '<span class="badge text-xs mt-2 inline-block" style="background:rgb(220 252 231);color:rgb(22 101 52)">English-friendly</span>';
      }
      html += '</button>';
    });
    grid.innerHTML = html;

    grid.querySelectorAll('.country-btn').forEach(function(btn) {
      btn.addEventListener('click', function() {
        var id = this.getAttribute('data-country');
        selectCountry(id);
      });
    });
  }

  function selectCountry(id) {
    var c = countries.find(function(x) { return x.id === id; });
    if (!c) return;
    selectedCountry = id;

    document.querySelectorAll('.country-btn').forEach(function(btn) {
      var isActive = btn.getAttribute('data-country') === id;
      btn.classList.toggle('border-violet-400', isActive);
      btn.classList.toggle('dark:border-violet-500', isActive);
      btn.classList.toggle('bg-violet-50', isActive);
      btn.classList.toggle('dark:bg-violet-900/20', isActive);
    });

    var panel = document.getElementById('country-detail');
    var html = '<div class="card p-6 md:p-8 fade-in">';
    html += '<div class="flex flex-col sm:flex-row sm:items-center justify-between gap-4 mb-6">';
    html += '<div class="flex items-center gap-4">';
    html += '<span class="text-4xl">' + c.flag + '</span>';
    html += '<div>';
    html += '<h2 class="text-2xl font-bold text-gray-900 dark:text-white">' + c.name + '</h2>';
    html += '<p class="text-gray-500 dark:text-gray-400">Language: ' + c.language + '</p>';
    html += '</div></div>';
    html += '<button class="add-compare-btn btn-secondary text-sm" data-country="' + c.id + '"><i data-lucide="git-compare" class="w-4 h-4 mr-1"></i> ' + (compareSet[c.id] ? 'Remove from comparison' : 'Add to comparison') + '</button>';
    html += '</div>';

    html += '<div class="grid md:grid-cols-2 gap-6">';

    html += '<div class="space-y-5">';
    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="file-text" class="w-4 h-4 text-violet-500"></i> Work Visa Language Requirement</h3>';
    html += '<p class="badge inline-block mb-2" style="background:rgb(220 252 231);color:rgb(22 101 52)">' + c.visaLanguage.requirement + '</p>';
    html += '<p class="text-sm text-gray-600 dark:text-gray-400">' + c.visaLanguage.detail + '</p>';
    html += '</div>';

    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="building-2" class="w-4 h-4 text-sky-500"></i> Workplace Language</h3>';
    html += '<p class="text-sm font-medium text-gray-700 dark:text-gray-300 mb-1">' + c.workplace.summary + '</p>';
    html += '<p class="text-sm text-gray-600 dark:text-gray-400">' + c.workplace.detail + '</p>';
    html += '</div>';

    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="coffee" class="w-4 h-4 text-amber-500"></i> Daily Life Language Needs</h3>';
    html += '<div class="flex items-center gap-2 mb-1">' + renderStars(c.dailyLife.rating) + ' <span class="text-sm text-gray-500 dark:text-gray-400">' + c.dailyLife.rating + '/5 (English sufficiency)</span></div>';
    html += '<p class="text-sm text-gray-600 dark:text-gray-400">' + c.dailyLife.detail + '</p>';
    html += '</div>';
    html += '</div>';

    html += '<div class="space-y-5">';
    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="landmark" class="w-4 h-4 text-red-500"></i> Government &amp; Admin</h3>';
    html += '<p class="text-sm text-gray-600 dark:text-gray-400">' + c.government + '</p>';
    html += '</div>';

    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="target" class="w-4 h-4 text-emerald-500"></i> Recommended Language Level</h3>';
    html += '<span class="badge inline-block" style="background:rgb(219 234 254);color:rgb(30 64 175)">' + c.recommendedLevel + '</span>';
    html += '<p class="text-xs text-gray-500 dark:text-gray-400 mt-1">For comfortable daily life and long-term stay</p>';
    html += '</div>';

    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="book-open" class="w-4 h-4 text-violet-500"></i> Language Learning Resources</h3>';
    html += '<ul class="space-y-1">';
    c.resources.forEach(function(r) {
      html += '<li class="text-sm text-gray-600 dark:text-gray-400 flex items-start gap-2"><i data-lucide="check" class="w-3.5 h-3.5 text-emerald-500 shrink-0 mt-0.5"></i> ' + r + '</li>';
    });
    html += '</ul></div>';

    html += '<div>';
    html += '<h3 class="font-semibold text-gray-900 dark:text-white flex items-center gap-2 mb-2"><i data-lucide="lightbulb" class="w-4 h-4 text-amber-500"></i> Tips for Getting By</h3>';
    html += '<ul class="space-y-1">';
    c.tips.forEach(function(t) {
      html += '<li class="text-sm text-gray-600 dark:text-gray-400 flex items-start gap-2"><i data-lucide="arrow-right" class="w-3.5 h-3.5 text-violet-500 shrink-0 mt-0.5"></i> ' + t + '</li>';
    });
    html += '</ul></div>';
    html += '</div>';

    html += '</div></div>';

    panel.innerHTML = html;
    panel.classList.remove('hidden');

    panel.querySelector('.add-compare-btn').addEventListener('click', function() {
      toggleCompare(this.getAttribute('data-country'));
    });

    if (window.lucide) lucide.createIcons();
    panel.scrollIntoView({ behavior: 'smooth', block: 'nearest' });
  }

  function toggleCompare(id) {
    if (compareSet[id]) {
      delete compareSet[id];
    } else {
      if (Object.keys(compareSet).length >= 3) return;
      compareSet[id] = true;
    }
    updateCompareBar();
    if (selectedCountry) selectCountry(selectedCountry);
  }

  function updateCompareBar() {
    var keys = Object.keys(compareSet);
    var bar = document.getElementById('compare-bar');
    document.getElementById('compare-count').textContent = keys.length;
    bar.classList.toggle('hidden', keys.length === 0);
  }

  function renderComparison() {
    var keys = Object.keys(compareSet);
    if (keys.length < 2) return;

    var selected = keys.map(function(id) {
      return countries.find(function(c) { return c.id === id; });
    }).filter(Boolean);

    var panel = document.getElementById('compare-panel');
    var html = '<div class="card p-6 md:p-8 fade-in">';
    html += '<div class="flex items-center justify-between mb-6">';
    html += '<h2 class="text-xl font-bold text-gray-900 dark:text-white flex items-center gap-2"><i data-lucide="git-compare" class="w-5 h-5 text-violet-600 dark:text-violet-400"></i> Side-by-Side Comparison</h2>';
    html += '<button id="close-compare-panel" class="btn-secondary text-sm"><i data-lucide="x" class="w-4 h-4 mr-1"></i> Close</button>';
    html += '</div>';

    html += '<div class="overflow-x-auto"><table class="w-full text-left text-sm">';
    html += '<thead><tr><th class="p-3 font-semibold text-gray-500 dark:text-gray-400 min-w-[140px]"></th>';
    selected.forEach(function(c) {
      html += '<th class="p-3 compare-col"><span class="text-2xl mr-2">' + c.flag + '</span><span class="font-bold text-gray-900 dark:text-white">' + c.name + '</span></th>';
    });
    html += '</tr></thead><tbody>';

    var rows = [
      { label: 'Language', icon: 'languages', key: function(c) { return c.language; } },
      { label: 'Visa Requirement', icon: 'file-text', key: function(c) { return c.visaLanguage.requirement; } },
      { label: 'Workplace', icon: 'building-2', key: function(c) { return c.workplace.summary; } },
      { label: 'English Sufficiency', icon: 'coffee', key: function(c) { return renderStars(c.dailyLife.rating) + ' ' + c.dailyLife.rating + '/5'; } },
      { label: 'Recommended Level', icon: 'target', key: function(c) { return '<span class="badge" style="background:rgb(219 234 254);color:rgb(30 64 175)">' + c.recommendedLevel + '</span>'; } },
      { label: 'English-Friendly', icon: 'check-circle', key: function(c) { return c.englishFriendly ? '<span class="text-emerald-600 dark:text-emerald-400 font-semibold flex items-center gap-1"><i data-lucide="check-circle" class="w-4 h-4"></i> Yes</span>' : '<span class="text-amber-600 dark:text-amber-400 font-semibold flex items-center gap-1"><i data-lucide="alert-circle" class="w-4 h-4"></i> Limited</span>'; } }
    ];

    rows.forEach(function(row) {
      html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
      html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="' + row.icon + '" class="w-4 h-4 inline mr-2 text-gray-400"></i>' + row.label + '</td>';
      selected.forEach(function(c) {
        html += '<td class="p-3 text-gray-600 dark:text-gray-400 compare-col">' + row.key(c) + '</td>';
      });
      html += '</tr>';
    });

    html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
    html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="lightbulb" class="w-4 h-4 inline mr-2 text-amber-500"></i>Top Tips</td>';
    selected.forEach(function(c) {
      html += '<td class="p-3 compare-col"><ul class="space-y-1">';
      c.tips.slice(0, 3).forEach(function(t) {
        html += '<li class="text-sm text-gray-600 dark:text-gray-400 flex items-start gap-1"><i data-lucide="arrow-right" class="w-3 h-3 text-violet-500 shrink-0 mt-0.5"></i>' + t + '</li>';
      });
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '<tr class="border-t border-gray-100 dark:border-gray-800">';
    html += '<td class="p-3 font-medium text-gray-700 dark:text-gray-300 whitespace-nowrap"><i data-lucide="book-open" class="w-4 h-4 inline mr-2 text-violet-500"></i>Resources</td>';
    selected.forEach(function(c) {
      html += '<td class="p-3 compare-col"><ul class="space-y-1">';
      c.resources.forEach(function(r) {
        html += '<li class="text-sm text-gray-600 dark:text-gray-400 flex items-start gap-1"><i data-lucide="check" class="w-3 h-3 text-emerald-500 shrink-0 mt-0.5"></i>' + r + '</li>';
      });
      html += '</ul></td>';
    });
    html += '</tr>';

    html += '</tbody></table></div></div>';

    panel.innerHTML = html;
    panel.classList.remove('hidden');

    document.getElementById('close-compare-panel').addEventListener('click', function() {
      panel.classList.add('hidden');
    });

    if (window.lucide) lucide.createIcons();
    panel.scrollIntoView({ behavior: 'smooth', block: 'start' });
  }

  // Init
  renderSummary();
  renderCountryGrid();

  document.getElementById('compare-btn').addEventListener('click', renderComparison);
  document.getElementById('clear-compare').addEventListener('click', function() {
    compareSet = {};
    updateCompareBar();
    document.getElementById('compare-panel').classList.add('hidden');
    if (selectedCountry) selectCountry(selectedCountry);
  });

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });

  // Copy link
  document.getElementById('copy-link-btn').addEventListener('click', function() {
    navigator.clipboard.writeText(window.location.href).then(function() {
      var btn = document.getElementById('copy-link-btn');
      btn.innerHTML = '<i data-lucide="check" class="w-4 h-4 text-emerald-500"></i>';
      if (window.lucide) lucide.createIcons();
      setTimeout(function() {
        btn.innerHTML = '<i data-lucide="link" class="w-4 h-4 text-gray-600 dark:text-gray-400"></i>';
        if (window.lucide) lucide.createIcons();
      }, 2000);
    });
  });

  // URL hash support for direct linking
  if (window.location.hash) {
    var hashId = window.location.hash.substring(1);
    var match = countries.find(function(c) { return c.id === hashId; });
    if (match) setTimeout(function() { selectCountry(hashId); }, 100);
  }
})();
</script>
{% endblock %}
