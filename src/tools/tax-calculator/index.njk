        { min: 300000, max: Infinity, rate: 47 }
      ],
      socialRate: 6.35,
      socialCap: 56844,
      marriedFactor: 1,
      notes: 'Social security ~6.35% capped at ~\u20AC56,844/year. Regional surcharges may vary. Beckham Law may apply for new residents (not modeled here).'
    },
    ie: {
      name: 'Ireland', emoji: '\u{1F1EE}\u{1F1EA}', currency: 'EUR', symbol: '\u20AC',
      brackets: [
        { min: 0, max: 42000, rate: 20 },
        { min: 42000, max: Infinity, rate: 40 }
      ],
      prsi: 4,
      usc: [
        { min: 0, max: 12012, rate: 0.5 },
        { min: 12012, max: 25760, rate: 2 },
        { min: 25760, max: 70044, rate: 4 },
        { min: 70044, max: Infinity, rate: 8 }
      ],
      marriedFactor: 1,
      marriedBracketIncrease: 51000,
      notes: 'Includes PRSI (4%) and USC (0.5-8%). Married couples may have the standard rate band increased to \u20AC51,000.'
    },
    se: {
      name: 'Sweden', emoji: '\u{1F1F8}\u{1F1EA}', currency: 'SEK', symbol: 'kr', eurRate: 0.087,
      brackets: [
        { min: 0, max: 614942, rate: 32 },
        { min: 614942, max: Infinity, rate: 52 }
      ],
      socialRate: 7,
      socialCap: 614942,
      marriedFactor: 1,
      notes: 'Amounts in SEK. Municipal tax ~32% (average). State tax 20% above ~615,000 SEK. Employee pension contribution ~7% capped. No joint filing.'
    },
    ch: {
      name: 'Switzerland', emoji: '\u{1F1E8}\u{1F1ED}', currency: 'CHF', symbol: 'CHF ', eurRate: 1.05,
      brackets: [
        { min: 0, max: 18900, rate: 0 },
        { min: 18900, max: 32800, rate: 2 },
        { min: 32800, max: 42900, rate: 4 },
        { min: 42900, max: 56500, rate: 6 },
        { min: 56500, max: 73600, rate: 8 },
        { min: 73600, max: 98000, rate: 10 },
        { min: 98000, max: 128400, rate: 12 },
        { min: 128400, max: 176000, rate: 14 },
        { min: 176000, max: Infinity, rate: 17.5 }
      ],
      socialRate: 6.4,
      marriedFactor: 1,
      notes: 'Amounts in CHF. Rates represent Zurich canton (federal + cantonal + municipal). Actual rates vary significantly by canton. Social contributions ~6.4% (AHV/IV/EO + ALV).'
    },
    pt: {
      name: 'Portugal', emoji: '\u{1F1F5}\u{1F1F9}', currency: 'EUR', symbol: '\u20AC',
      brackets: [
        { min: 0, max: 7703, rate: 14.5 },
        { min: 7703, max: 11623, rate: 21 },
        { min: 11623, max: 16472, rate: 26.5 },
        { min: 16472, max: 21321, rate: 28.5 },
        { min: 21321, max: 27146, rate: 35 },
        { min: 27146, max: 39791, rate: 37 },
        { min: 39791, max: 51997, rate: 43.5 },
        { min: 51997, max: 81199, rate: 45 },
        { min: 81199, max: Infinity, rate: 48 }
      ],
      socialRate: 11,
      marriedFactor: 1,
      notes: 'Social security ~11%. NHR (Non-Habitual Resident) regime offers a flat 20% for qualifying professions for 10 years (not modeled here).'
    },
    pl: {
      name: 'Poland', emoji: '\u{1F1F5}\u{1F1F1}', currency: 'PLN', symbol: 'z\u0142', eurRate: 0.233,
      brackets: [
        { min: 0, max: 30000, rate: 0 },
        { min: 30000, max: 120000, rate: 12 },
        { min: 120000, max: Infinity, rate: 32 }
      ],
      socialRate: 13.71,
      socialCap: 234720,
      healthRate: 9,
      marriedFactor: 2,
      notes: 'Amounts in PLN. Tax-free allowance 30,000 PLN. Social contributions ~13.71% + 9% health insurance (not tax-deductible). Joint filing available for married couples.'
    },
    dk: {
      name: 'Denmark', emoji: '\u{1F1E9}\u{1F1F0}', currency: 'DKK', symbol: 'kr', eurRate: 0.134,
      brackets: [
        { min: 0, max: 49700, rate: 0 },
        { min: 49700, max: 588900, rate: 37.09 },
        { min: 588900, max: Infinity, rate: 52.07 }
      ],
      laborMarket: 8,
      socialRate: 0,
      marriedFactor: 1,
      notes: 'Amounts in DKK. Labour market contribution (AM-bidrag) 8% off the top. Personal deduction ~49,700 DKK. Top tax 15% applies above ~588,900 DKK (combined ~52%).'
    }
  };

  var eurRates = { EUR: 1, GBP: 1.17, SEK: 0.087, CHF: 1.05, PLN: 0.233, DKK: 0.134 };

  function toLocal(eurAmount, country) {
    var c = countries[country];
    if (!c || c.currency === 'EUR') return eurAmount;
    return eurAmount * c.eurRate ? (eurAmount / eurRates[c.currency]) : eurAmount;
  }

  function convertToEur(localAmount, currency) {
    return localAmount * (eurRates[currency] || 1);
  }

  function calcTax(gross, brackets) {
    var tax = 0;
    for (var i = 0; i < brackets.length; i++) {
      var b = brackets[i];
      var upper = b.max === Infinity ? gross : b.max;
      if (gross > b.min) {
        tax += (Math.min(gross, upper) - b.min) * (b.rate / 100);
      }
    }
    return tax;
  }

  function calculate(grossEur, countryId, status, apply30) {
    var c = countries[countryId];
    if (!c) return null;

    var localGross = grossEur;
    if (c.currency !== 'EUR') {
      localGross = grossEur / eurRates[c.currency];
    }

    var taxableIncome = localGross;
    var applied30 = false;

    // Denmark: labour market contribution is deducted before income tax
    var laborMarketTax = 0;
    if (c.laborMarket) {
      laborMarketTax = localGross * (c.laborMarket / 100);
      taxableIncome = localGross - laborMarketTax;
    }

    // Netherlands 30% ruling
    if (countryId === 'nl' && apply30) {
      taxableIncome = localGross * 0.7;
      applied30 = true;
    }

    // Married income splitting (Germany, Poland)
    var effectiveIncome = taxableIncome;
    if (status === 'married' && c.marriedFactor === 2) {
      effectiveIncome = taxableIncome / 2;
    }

    // Ireland married bracket increase
    var brackets = c.brackets;
    if (countryId === 'ie' && status === 'married' && c.marriedBracketIncrease) {
      brackets = [
        { min: 0, max: c.marriedBracketIncrease, rate: 20 },
        { min: c.marriedBracketIncrease, max: Infinity, rate: 40 }
      ];
    }

    var incomeTax = calcTax(effectiveIncome, brackets);

    // Germany: married splitting - double the tax on half income
    if (status === 'married' && c.marriedFactor === 2) {
      incomeTax = incomeTax * 2;
    }

    // Germany: solidarity surcharge
    var solidarity = 0;
    if (c.solidaritySurcharge && incomeTax > c.solidarityThreshold) {
      solidarity = (incomeTax - c.solidarityThreshold) * (c.solidaritySurcharge / 100);
    }
    incomeTax += solidarity;

    // Social contributions
    var socialContrib = 0;
    if (c.socialRate) {
      var socialBase = localGross;
      if (c.socialCap) socialBase = Math.min(localGross, c.socialCap);
      socialContrib = socialBase * (c.socialRate / 100);
    }

    // UK National Insurance
    if (c.niRate) {
      if (localGross > c.niMin) {
        var niBase = Math.min(localGross, c.niMax) - c.niMin;
        socialContrib = niBase * (c.niRate / 100);
        if (localGross > c.niMax && c.niAboveRate) {
          socialContrib += (localGross - c.niMax) * (c.niAboveRate / 100);
        }
      }
    }

    // Ireland PRSI + USC
    if (c.prsi) {
      socialContrib = localGross * (c.prsi / 100);
    }
    if (c.usc) {
      socialContrib += calcTax(localGross, c.usc);
    }

    // Poland health insurance
    if (c.healthRate) {
      socialContrib += (localGross - socialContrib) * (c.healthRate / 100);
    }

    // Denmark labor market tax counted as social
    socialContrib += laborMarketTax;

    var totalDeductions = incomeTax + socialContrib;
    var netLocal = Math.max(0, localGross - totalDeductions);
    var netEur = c.currency === 'EUR' ? netLocal : netLocal * eurRates[c.currency];
    var grossLocal = localGross;

    return {
      countryId: countryId,
      country: c,
      grossLocal: grossLocal,
      grossEur: grossEur,
      incomeTaxLocal: incomeTax,
      socialLocal: socialContrib,
      netLocal: netLocal,
      netEur: netEur,
      totalDeductions: totalDeductions,
      effectiveRate: grossLocal > 0 ? (totalDeductions / grossLocal * 100) : 0,
      applied30: applied30
    };
  }

  function fmt(val, sym) {
    var rounded = Math.round(val);
    var formatted = rounded.toLocaleString('en-US');
    if (sym && sym.length > 1) return sym + formatted;
    return (sym || '') + formatted;
  }

  function fmtEur(val) { return '\u20AC' + Math.round(val).toLocaleString('en-US'); }

  // Country checkbox logic
  var checkboxes = document.querySelectorAll('.country-check');
  var countSpan = document.getElementById('tc-count');
  var rulingWrap = document.getElementById('tc-ruling-wrap');

  function updateSelectionCount() {
    var checked = document.querySelectorAll('.country-check:checked');
    countSpan.textContent = checked.length;

    var nlChecked = document.getElementById('chk-nl').checked;
    rulingWrap.classList.toggle('hidden', !nlChecked);

    if (checked.length >= 4) {
      checkboxes.forEach(function(cb) {
        if (!cb.checked) cb.disabled = true;
      });
    } else {
      checkboxes.forEach(function(cb) { cb.disabled = false; });
    }
  }

  checkboxes.forEach(function(cb) {
    cb.addEventListener('change', updateSelectionCount);
  });

  // 30% ruling toggle
  var rulingToggle = document.getElementById('tc-ruling-toggle');
  var ruling30Active = false;

  rulingToggle.addEventListener('click', function() {
    ruling30Active = !ruling30Active;
    rulingToggle.setAttribute('aria-checked', ruling30Active);
    if (ruling30Active) {
      rulingToggle.classList.remove('bg-gray-300', 'dark:bg-gray-600');
      rulingToggle.classList.add('bg-indigo-600');
      rulingToggle.querySelector('.toggle-thumb').style.transform = 'translateX(1.25rem)';
    } else {
      rulingToggle.classList.add('bg-gray-300', 'dark:bg-gray-600');
      rulingToggle.classList.remove('bg-indigo-600');
      rulingToggle.querySelector('.toggle-thumb').style.transform = 'translateX(0)';
    }
  });

  // Main calculation
  document.getElementById('tc-calculate').addEventListener('click', function() {
    var grossEur = parseFloat(document.getElementById('tc-salary').value);
    if (!grossEur || grossEur <= 0) return;

    var status = document.getElementById('tc-status').value;
    var period = document.getElementById('tc-period').value;
    var divisor = period === 'monthly' ? 12 : 1;
    var periodLabel = period === 'monthly' ? '/mo' : '/yr';

    var selected = [];
    checkboxes.forEach(function(cb) {
      if (cb.checked) selected.push(cb.value);
    });
    if (selected.length < 2) {
      alert('Please select at least 2 countries to compare.');
      return;
    }

    var results = selected.map(function(id) {
      return calculate(grossEur, id, status, ruling30Active);
    }).filter(Boolean);

    if (results.length < 2) return;

    results.sort(function(a, b) { return a.effectiveRate - b.effectiveRate; });

    var bestNet = Math.max.apply(null, results.map(function(r) { return r.netEur; }));
    var maxRate = Math.max.apply(null, results.map(function(r) { return r.effectiveRate; }));

    // Render comparison cards
    var cardsContainer = document.getElementById('tc-cards');
    cardsContainer.className = 'grid grid-cols-1 gap-6 mb-8';
    if (results.length === 2) cardsContainer.className += ' md:grid-cols-2';
    else if (results.length === 3) cardsContainer.className += ' md:grid-cols-3';
    else cardsContainer.className += ' md:grid-cols-2 lg:grid-cols-4';

    var cardsHtml = results.map(function(r) {
      var isBest = r.netEur === bestNet;
      var s = r.country.symbol;
      var currNote = r.country.currency !== 'EUR' ? '<span class="text-xs text-gray-400">(' + fmtEur(r.netEur / divisor) + periodLabel + ')</span>' : '';
      var rulingBadge = r.applied30 ? '<span class="inline-block text-xs bg-yellow-100 dark:bg-yellow-900/30 text-yellow-700 dark:text-yellow-400 px-2 py-0.5 rounded-full mb-2">30% Ruling Applied</span><br>' : '';

      return '<div class="card p-6 compare-col' + (isBest ? ' ring-2 ring-green-500 dark:ring-green-400' : '') + '">' +
        (isBest ? '<span class="inline-block text-xs font-semibold bg-green-100 dark:bg-green-900/30 text-green-700 dark:text-green-400 px-2.5 py-1 rounded-full mb-3"><i data-lucide="trophy" class="w-3 h-3 inline mr-1"></i>Best Net Pay</span>' : '') +
        '<div class="flex items-center gap-2 mb-4">' +
          '<span class="text-2xl">' + r.country.emoji + '</span>' +
          '<h3 class="text-lg font-semibold text-gray-900 dark:text-white">' + r.country.name + '</h3>' +
        '</div>' +
        rulingBadge +
        '<div class="space-y-3">' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Gross Salary</span><span class="font-medium text-gray-900 dark:text-white">' + fmt(r.grossLocal / divisor, s) + '</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Income Tax</span><span class="font-medium text-red-600 dark:text-red-400">-' + fmt(r.incomeTaxLocal / divisor, s) + '</span></div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Social Contributions</span><span class="font-medium text-orange-600 dark:text-orange-400">-' + fmt(r.socialLocal / divisor, s) + '</span></div>' +
          '<div class="border-t border-gray-200 dark:border-gray-700 pt-3 flex justify-between">' +
            '<span class="text-sm font-semibold text-gray-700 dark:text-gray-300">Net Salary</span>' +
            '<div class="text-right"><span class="text-xl font-bold text-green-600 dark:text-green-400">' + fmt(r.netLocal / divisor, s) + '</span> ' + currNote + '</div>' +
          '</div>' +
          '<div class="flex justify-between"><span class="text-sm text-gray-500 dark:text-gray-400">Effective Tax Rate</span><span class="font-semibold text-gray-900 dark:text-white">' + r.effectiveRate.toFixed(1) + '%</span></div>' +
        '</div>' +
        '<div class="mt-4">' +
          '<div class="w-full h-3 rounded-full overflow-hidden flex bg-gray-200 dark:bg-gray-700">' +
            '<div class="bg-green-500 h-full tax-bar" style="width:' + ((r.netLocal / r.grossLocal) * 100).toFixed(1) + '%"></div>' +
            '<div class="bg-red-400 h-full tax-bar" style="width:' + ((r.incomeTaxLocal / r.grossLocal) * 100).toFixed(1) + '%"></div>' +
            '<div class="bg-orange-400 h-full tax-bar" style="width:' + ((r.socialLocal / r.grossLocal) * 100).toFixed(1) + '%"></div>' +
          '</div>' +
          '<div class="flex gap-3 mt-1.5 text-xs text-gray-400 dark:text-gray-500">' +
            '<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-green-500 inline-block"></span>Net</span>' +
            '<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-red-400 inline-block"></span>Tax</span>' +
            '<span class="flex items-center gap-1"><span class="w-2 h-2 rounded-full bg-orange-400 inline-block"></span>Social</span>' +
          '</div>' +
        '</div>' +
        '<p class="text-xs text-gray-400 dark:text-gray-500 mt-3 leading-relaxed">' + (r.country.notes || '') + '</p>' +
      '</div>';
    }).join('');
    cardsContainer.innerHTML = cardsHtml;

    // Effective tax rate bars
    var barsHtml = results.map(function(r) {
      var pct = maxRate > 0 ? (r.effectiveRate / 60 * 100) : 0;
      pct = Math.min(pct, 100);
      var barColor = r.effectiveRate < 25 ? 'bg-green-500' : r.effectiveRate < 35 ? 'bg-yellow-500' : r.effectiveRate < 45 ? 'bg-orange-500' : 'bg-red-500';
      return '<div class="flex items-center gap-4">' +
        '<span class="text-sm font-medium text-gray-700 dark:text-gray-300 w-32 shrink-0 flex items-center gap-2"><span>' + r.country.emoji + '</span> ' + r.country.name + '</span>' +
        '<div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-7 overflow-hidden">' +
          '<div class="tax-bar ' + barColor + ' h-full rounded-full flex items-center justify-end pr-3" style="width:' + pct + '%;min-width:3rem">' +
            '<span class="text-xs font-semibold text-white">' + r.effectiveRate.toFixed(1) + '%</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
    document.getElementById('tc-bars').innerHTML = barsHtml;

    // Net salary bars (in EUR for fair comparison)
    var maxNetEur = Math.max.apply(null, results.map(function(r) { return r.netEur; }));
    var netBarsHtml = results.map(function(r) {
      var pct = maxNetEur > 0 ? (r.netEur / maxNetEur * 100) : 0;
      var isBest = r.netEur === bestNet;
      return '<div class="flex items-center gap-4">' +
        '<span class="text-sm font-medium text-gray-700 dark:text-gray-300 w-32 shrink-0 flex items-center gap-2"><span>' + r.country.emoji + '</span> ' + r.country.name + '</span>' +
        '<div class="flex-1 bg-gray-200 dark:bg-gray-700 rounded-full h-7 overflow-hidden">' +
          '<div class="tax-bar ' + (isBest ? 'bg-green-500' : 'bg-indigo-500') + ' h-full rounded-full flex items-center justify-end pr-3" style="width:' + pct + '%;min-width:3rem">' +
            '<span class="text-xs font-semibold text-white">' + fmtEur(r.netEur / divisor) + periodLabel + '</span>' +
          '</div>' +
        '</div>' +
      '</div>';
    }).join('');
    document.getElementById('tc-net-bars').innerHTML = netBarsHtml;

    document.getElementById('tc-results-section').classList.remove('hidden');
    document.getElementById('tc-results-section').scrollIntoView({ behavior: 'smooth', block: 'start' });
    if (window.lucide) lucide.createIcons();
  });

  // FAQ toggles
  document.querySelectorAll('.faq-toggle').forEach(function(btn) {
    btn.addEventListener('click', function() {
      var item = btn.closest('.faq-item');
      var content = item.querySelector('.faq-content');
      var icon = item.querySelector('.faq-icon');
      var isOpen = !content.classList.contains('hidden');
      content.classList.toggle('hidden', isOpen);
      icon.style.transform = isOpen ? '' : 'rotate(180deg)';
      btn.setAttribute('aria-expanded', !isOpen);
    });
  });
})();
</script>
