    canada: {
      name: 'Canada',
      flag: '\u{1F1E8}\u{1F1E6}',
      guideUrl: '/resources/country-guides/canada/',
      items: [
        { id: 'ca-nophoto', category: 'Format', label: 'Do NOT include a photo', detail: 'Canadian human rights laws prohibit discrimination. Photos are strongly discouraged.', required: true },
        { id: 'ca-length', category: 'Format', label: 'Keep CV to 2 pages', detail: 'Two pages is standard. One page for entry-level. Never exceed three.', required: true },
        { id: 'ca-lang', category: 'Language', label: 'English or French (depending on province)', detail: 'English in most provinces. French in Quebec. Bilingual CVs may be requested by federal employers.', required: true },
        { id: 'ca-cover', category: 'Cover Letter', label: 'Cover letter expected', detail: 'A cover letter is standard for most applications. Tailor it to the specific job posting.', required: true },
        { id: 'ca-nodetails', category: 'Personal Info', label: 'Do NOT include personal details', detail: 'No age, marital status, religion, SIN, or photo. Only name, phone, email, LinkedIn, and city/province.', required: true },
        { id: 'ca-date', category: 'Format', label: 'Use YYYY-MM-DD date format (ISO standard)', detail: 'Canada officially uses the ISO format. MM/DD/YYYY is also common in English Canada.', required: true },
        { id: 'ca-achievements', category: 'Tip', label: 'Use action verbs and quantified achievements', detail: 'Canadian employers value results-oriented CVs. Start bullets with action verbs.', required: false },
        { id: 'ca-ats', category: 'Tip', label: 'Optimize for ATS (Applicant Tracking Systems)', detail: 'Many Canadian companies use ATS. Use standard section headings and include keywords from the job posting.', required: false },
        { id: 'ca-diff', category: 'Key Difference', label: 'Use "resume" not "CV" (unless academic)', detail: 'In Canada, it\'s called a "resume" for most jobs. "CV" is only used for academic or research positions.', required: false }
      ],
      resources: [
        { name: 'Job Bank Canada', url: 'https://www.jobbank.gc.ca/home' },
        { name: 'Canada.ca Immigration', url: 'https://www.canada.ca/en/immigration-refugees-citizenship.html' }
      ]
    }
  };

  const checkedItems = new Set();

  document.getElementById('ra-country').addEventListener('change', function() {
    const key = this.value;
    const container = document.getElementById('ra-results');
    if (!key || !countryData[key]) {
      container.classList.add('hidden');
      return;
    }
    checkedItems.clear();
    render(countryData[key], key);
    container.classList.remove('hidden');
  });

  function render(data, key) {
    const header = document.getElementById('ra-header');
    header.innerHTML = `
      <div class="flex items-center gap-3 mb-3">
        <span class="text-4xl">${data.flag}</span>
        <div>
          <h2 class="text-2xl font-extrabold text-gray-900 dark:text-white">${data.name}</h2>
          ${data.guideUrl ? `<a href="${data.guideUrl}" class="text-sm text-brand-600 dark:text-brand-400 hover:underline">View country guide &rarr;</a>` : ''}
        </div>
      </div>
      <p class="text-sm text-gray-500 dark:text-gray-400">${data.items.length} items to review. Check off each item as you update your CV.</p>
    `;

    const cl = document.getElementById('ra-checklist');
    const categories = {};
    data.items.forEach(item => {
      if (!categories[item.category]) categories[item.category] = [];
      categories[item.category].push(item);
    });

    let html = '';
    Object.entries(categories).forEach(([cat, items]) => {
      html += `<h3 class="text-sm font-bold text-gray-500 dark:text-gray-400 uppercase tracking-wider mt-6 mb-3 first:mt-0">${cat}</h3>`;
      items.forEach(item => {
        html += `
          <label class="card p-4 flex items-start gap-3 cursor-pointer hover:ring-2 hover:ring-brand-500/30 transition-all">
            <input type="checkbox" id="${item.id}" class="ra-check mt-1 w-5 h-5 rounded border-gray-300 dark:border-gray-600 text-brand-600 focus:ring-brand-500 shrink-0" />
            <div class="flex-1 min-w-0">
              <div class="flex items-center gap-2 flex-wrap">
                <span class="font-semibold text-gray-900 dark:text-white text-sm">${item.label}</span>
                ${item.required ? '<span class="text-xs font-medium text-red-600 dark:text-red-400 bg-red-50 dark:bg-red-900/30 px-1.5 py-0.5 rounded">Required</span>' : '<span class="text-xs font-medium text-gray-500 dark:text-gray-400 bg-gray-100 dark:bg-gray-800 px-1.5 py-0.5 rounded">Optional</span>'}
              </div>
              <p class="text-xs text-gray-500 dark:text-gray-400 mt-1">${item.detail}</p>
            </div>
          </label>
        `;
      });
    });
    cl.innerHTML = html;

    const res = document.getElementById('ra-resources');
    let resHtml = '<h4 class="font-semibold text-blue-800 dark:text-blue-300 mb-2"><i data-lucide="link" class="w-4 h-4 inline mr-1"></i>Useful Resources</h4><ul class="space-y-1">';
    data.resources.forEach(r => {
      resHtml += `<li><a href="${r.url}" target="_blank" rel="noopener" class="text-sm text-blue-700 dark:text-blue-400 hover:underline">${r.name} &rarr;</a></li>`;
    });
    resHtml += '</ul>';
    res.innerHTML = resHtml;

    document.querySelectorAll('.ra-check').forEach(cb => {
      cb.addEventListener('change', function() {
        if (this.checked) checkedItems.add(this.id);
        else checkedItems.delete(this.id);
        updateProgress(data.items.length);
      });
    });

    updateProgress(data.items.length);
    if (window.lucide) lucide.createIcons();
  }

  function updateProgress(total) {
    const pct = Math.round((checkedItems.size / total) * 100);
    document.getElementById('ra-pct').textContent = pct + '%';
    document.getElementById('ra-bar').style.width = pct + '%';
  }
})();
</script>
