layout: layouts/base.njk
title: "International Resume Adapter | Customize Your CV for Any Country"
description: "Adapt your resume for international job applications. Get country-specific requirements, format guidelines, and a personalized checklist for Germany, UK, Netherlands, and more."
---

{% block structuredData %}
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "WebApplication",
  "name": "International Resume Adapter",
  "url": "{{ site.url }}{{ page.url }}",
  "description": "{{ description }}",
  "applicationCategory": "Utility",
  "operatingSystem": "All",
  "offers": { "@type": "Offer", "price": "0", "priceCurrency": "USD" },
  "author": { "@type": "Organization", "name": "{{ site.name }}", "url": "{{ site.url }}" }
}
</script>
<script type="application/ld+json">
{
  "@context": "https://schema.org",
  "@type": "FAQPage",
  "mainEntity": [
    {
      "@type": "Question",
      "name": "Should I include a photo on my international resume?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "It depends on the country. Germany and Switzerland expect a professional photo. France considers it common practice. The UK, Ireland, Australia, and Canada strongly advise against photos due to anti-discrimination laws."
      }
    },
    {
      "@type": "Question",
      "name": "What is the ideal CV length for international applications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most countries expect 1-2 pages. France prefers a single page. Switzerland allows 2-3 pages. Australia and Canada allow 2-3 pages for senior roles. Always prioritize relevance over length."
      }
    },
    {
      "@type": "Question",
      "name": "Do I need a cover letter for European job applications?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Most European countries expect a cover letter. In Germany it's called an Anschreiben, in the Netherlands a motivatiebrief, and in France a lettre de motivation. The UK and Ireland also expect cover letters. In some countries, especially for tech roles, it may be optional."
      }
    },
    {
      "@type": "Question",
      "name": "What date format should I use on my international resume?",
      "acceptedAnswer": {
        "@type": "Answer",
        "text": "Use the local format: DD.MM.YYYY for Germany and Switzerland, DD/MM/YYYY for the UK, Ireland, France, and Australia. Canada uses YYYY-MM-DD (ISO format) or MM/DD/YYYY depending on the region."
      }
    }
  ]
}
</script>
